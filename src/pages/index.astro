      },
      "knowsAbout": [
        "home selling",
        "home buying",
        "real estate pricing strategy",
        "South Denver Metro real estate",
        "comparative market analysis",
        "real estate negotiation",
        "investment property analysis"
      ],
      "hasCredential": {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "Professional Certification",
        "name": "Real Estate Negotiation Expert (RENE)"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "47",
        "bestRating": "5"
      },
      "sameAs": [
        "https://jacobstark.8z.com/",
        "https://www.google.com/maps/place/?q=Jacob+Stark+Real+Estate",
        "https://www.zillow.com/profile/jacobstarkrealtor",
        "https://www.realtor.com/realestateagents/5ef4c015aa95460011ac4a5b",
        "https://www.linkedin.com/in/jacobstark",
        "https://www.instagram.com/jacobstark_realtor/",
        "https://www.facebook.com/jacobstarkrealtor/",
        "https://www.youtube.com/@selling303",
        "https://www.youtube.com/channel/UCTr7LNftWL7F63Bw-rcdxLg",
