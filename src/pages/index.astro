---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Selling 303 | Jacob Stark — South Denver Metro Real Estate"
  description="Jacob Stark guides families through buying and selling in Littleton, Highlands Ranch, Centennial, and the South Denver Metro. Clarity, confidence, and control — from the first conversation to closing day."
  ogTitle="Selling 303 | Jacob Stark — South Denver Metro Real Estate"
  ogDescription="Buying or selling in South Denver Metro? Jacob Stark guides you through every step so you feel clarity, confidence, and in control — from the first conversation to closing day."
  ogUrl="https://selling303.com"
  ogImage="https://selling303.com/images/og-home.jpg"
  currentPage="home"
  headerVariant="transparent"
>
  <Fragment slot="head">
    <script src="https://em.realscout.com/widgets/realscout-web-components.umd.js" type="module" is:inline></script>
    <style>
      realscout-advanced-search {
        --rs-as-button-text-color: #ffffff;
        --rs-as-background-color: #ffffff;
        --rs-as-button-color: #c8965a;
        --rs-as-widget-width: 100% !important;
      }
      realscout-home-value {
        --rs-hvw-background-color: transparent;
        --rs-hvw-title-color: #ffffff;
        --rs-hvw-subtitle-color: rgba(255, 255, 255, 0.7);
        --rs-hvw-primary-button-text-color: #ffffff;
        --rs-hvw-primary-button-color: #c8965a;
        --rs-hvw-secondary-button-text-color: #c8965a;
        --rs-hvw-secondary-button-color: #ffffff;
        --rs-hvw-widget-width: auto;
      }
    </style>

    <!-- Schema: LocalBusiness -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "RealEstateAgent",
      "name": "Jacob Stark — Selling 303",
      "description": "Your guide through South Denver Metro real estate — helping families buy and sell with clarity, confidence, and control.",
      "url": "https://selling303.com",
      "telephone": "+1-303-997-0634",
      "email": "jacob@selling303.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Littleton",
        "addressRegion": "CO",
        "postalCode": "80120",
        "addressCountry": "US"
      },
      "areaServed": [
        {"@type": "City", "name": "Littleton"},
        {"@type": "City", "name": "Highlands Ranch"},
        {"@type": "City", "name": "Centennial"},
        {"@type": "City", "name": "Englewood"},
        {"@type": "City", "name": "Parker"},
        {"@type": "City", "name": "Lakewood"},
        {"@type": "City", "name": "Lone Tree"},
        {"@type": "City", "name": "Castle Pines"},
        {"@type": "City", "name": "Greenwood Village"}
      ],
      "memberOf": {
        "@type": "Organization",
        "name": "8z Real Estate"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "52"
      }
    }
    </script>

    <!-- RealEstateAgent Schema -->
    <script type="application/ld+json" is:inline>
    {
