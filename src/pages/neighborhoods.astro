  <script is:inline>
  (function () {
    // Scoring map: each answer value → { neighborhoodId: points }
    var scoring = {
      q1: {
        'commute-dtc':        { centennial: 3, englewood: 2, 'greenwood-village': 2, 'lone-tree': 1 },
        'mountain-access':    { lakewood: 3, 'castle-pines': 2, littleton: 1 },
        'walkable-downtown':  { littleton: 3, parker: 2, englewood: 1 },
        'space-privacy':      { 'castle-pines': 3, parker: 2, 'highlands-ranch': 1 },
        'newer-construction': { 'highlands-ranch': 2, 'lone-tree': 2, parker: 2, centennial: 1 }
      },
      q2: {
        'under-650k':  { englewood: 3, lakewood: 3 },
        '650k-750k':   { littleton: 2, centennial: 2, englewood: 1, parker: 2, lakewood: 1 },
        '750k-950k':   { 'highlands-ranch': 2, 'lone-tree': 2, parker: 1, centennial: 1 },
        '950k-plus':   { 'castle-pines': 3, 'greenwood-village': 3, 'lone-tree': 1 }
      },
      q3: {
        'established-character': { littleton: 3, englewood: 2, centennial: 1 },
        'master-planned':        { 'highlands-ranch': 3, 'lone-tree': 2 },
        'small-town':            { parker: 3, littleton: 2 },
        'luxury-exclusive':      { 'greenwood-village': 3, 'castle-pines': 2, 'lone-tree': 1 }
      }
    };

    var displayNames = {
      'littleton': 'Littleton',
      'highlands-ranch': 'Highlands Ranch',
      'centennial': 'Centennial',
      'englewood': 'Englewood',
      'parker': 'Parker',
      'lakewood': 'Lakewood',
      'lone-tree': 'Lone Tree',
      'castle-pines': 'Castle Pines',
      'greenwood-village': 'Greenwood Village'
    };

    var answers = { q1: null, q2: null, q3: null };

    // Option selection
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.quiz-option');
      if (!btn) return;
      var q = btn.dataset.q;
      var container = btn.closest('.quiz-options');
      container.querySelectorAll('.quiz-option').forEach(function (b) { b.classList.remove('selected'); });
      btn.classList.add('selected');
      answers[q] = btn.dataset.val;
      // Enable next button for this step
      var stepNum = q.replace('q', '');
      var nextBtn = document.getElementById('next-' + stepNum);
      if (nextBtn) nextBtn.disabled = false;
    });

    // Navigation
    function showStep(n) {
      document.querySelectorAll('.quiz-step').forEach(function (s) { s.classList.remove('active'); });
      var step = document.getElementById('step-' + n);
      if (step) step.classList.add('active');
    }

    document.getElementById('next-1').addEventListener('click', function () {
      if (!answers.q1) return;
      showStep(2);
    });
    document.getElementById('back-2').addEventListener('click', function () { showStep(1); });
    document.getElementById('next-2').addEventListener('click', function () {
      if (!answers.q2) return;
      showStep(3);
    });
    document.getElementById('back-3').addEventListener('click', function () { showStep(2); });
    document.getElementById('next-3').addEventListener('click', function () {
      if (!answers.q3) return;
      showResults();
    });
    document.getElementById('restart-quiz').addEventListener('click', function () {
      answers = { q1: null, q2: null, q3: null };
      document.querySelectorAll('.quiz-option').forEach(function (b) { b.classList.remove('selected'); });
      ['next-1','next-2','next-3'].forEach(function (id) {
        var btn = document.getElementById(id);
        if (btn) btn.disabled = true;
      });
      document.querySelectorAll('.quiz-step').forEach(function (s) { s.classList.remove('active'); });
      document.getElementById('quiz-results').classList.remove('active');
      document.getElementById('step-1').classList.add('active');
      clearHighlights();
    });

    function showResults() {
      // Tally scores
      var scores = {};
      Object.keys(displayNames).forEach(function (id) { scores[id] = 0; });
      ['q1','q2','q3'].forEach(function (q) {
        var val = answers[q];
        if (!val || !scoring[q][val]) return;
        var map = scoring[q][val];
        Object.keys(map).forEach(function (id) { scores[id] += map[id]; });
      });

      // Sort and pick top 3
      var sorted = Object.keys(scores).sort(function (a, b) { return scores[b] - scores[a]; });
      var top = sorted.slice(0, 3).filter(function (id) { return scores[id] > 0; });

      // Show results panel
      document.querySelectorAll('.quiz-step').forEach(function (s) { s.classList.remove('active'); });
      var resultsEl = document.getElementById('quiz-results');
      resultsEl.classList.add('active');

      var chipsEl = document.getElementById('results-chips');
      chipsEl.innerHTML = '';
      top.forEach(function (id) {
        var chip = document.createElement('span');
        chip.className = 'quiz-result-chip';
        chip.textContent = displayNames[id];
        chipsEl.appendChild(chip);
      });

      // Highlight cards
      highlightCards(top);

      // Scroll to neighborhoods section
      setTimeout(function () {
        var nbSection = document.getElementById('neighborhoods');
        if (nbSection) nbSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 400);
    }

    function highlightCards(topIds) {
      var cards = document.querySelectorAll('.nbhd-card');
      cards.forEach(function (card) {
        var id = card.dataset.id;
        if (topIds.indexOf(id) !== -1) {
          card.classList.add('highlighted');
        } else {
          card.classList.remove('highlighted');
        }
      });

      // Reorder: highlighted first
      var grid = document.getElementById('neighborhoods-grid');
      var highlighted = [], rest = [];
      cards.forEach(function (card) {
        if (card.classList.contains('highlighted')) highlighted.push(card);
        else rest.push(card);
      });
      highlighted.concat(rest).forEach(function (card) { grid.appendChild(card); });

      // Show match header
      var header = document.getElementById('match-header');
      var namesEl = document.getElementById('match-names');
      header.classList.add('visible');
      namesEl.textContent = topIds.map(function (id) { return displayNames[id]; }).join(', ');
    }

    function clearHighlights() {
      document.querySelectorAll('.nbhd-card').forEach(function (card) {
        card.classList.remove('highlighted');
      });
      document.getElementById('match-header').classList.remove('visible');
    }
  })();
  </script>
