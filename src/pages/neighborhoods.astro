---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getImage } from 'astro:assets';

import nbLittletonSrc from '../assets/images/neighborhood-littleton.jpg';
import nbHighlandsRanchSrc from '../assets/images/neighborhood-highlands-ranch.jpg';
import nbCentennialSrc from '../assets/images/neighborhood-centennial.jpg';
import nbEnglewoodSrc from '../assets/images/neighborhood-englewood.jpg';
import nbParkerSrc from '../assets/images/neighborhood-parker.jpg';
import nbLakewoodSrc from '../assets/images/neighborhood-lakewood.jpg';

const nbLittleton = await getImage({ src: nbLittletonSrc, format: 'webp', quality: 80, width: 800 });
const nbHighlandsRanch = await getImage({ src: nbHighlandsRanchSrc, format: 'webp', quality: 80, width: 800 });
const nbCentennial = await getImage({ src: nbCentennialSrc, format: 'webp', quality: 80, width: 800 });
const nbEnglewood = await getImage({ src: nbEnglewoodSrc, format: 'webp', quality: 80, width: 800 });
const nbParker = await getImage({ src: nbParkerSrc, format: 'webp', quality: 80, width: 800 });
const nbLakewood = await getImage({ src: nbLakewoodSrc, format: 'webp', quality: 80, width: 800 });
---

<BaseLayout headerVariant="solid" title="Neighborhoods | Selling 303 — South Denver Metro Communities" description="Explore South Denver Metro neighborhoods — Littleton, Highlands Ranch, Centennial, Englewood, Parker, Lakewood, Lone Tree, Castle Pines, and Greenwood Village. Market stats, lifestyle info, and active listings." currentPage="neighborhoods">
  <Fragment slot="head">
    <!-- RealScout widget -->
    <script src="https://em.realscout.com/widgets/realscout-web-components.umd.js" type="module" is:inline></script>

    <!-- Schema: WebPage -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "South Denver Metro Neighborhoods | Selling 303",
      "url": "https://selling303.com/neighborhoods",
      "description": "Explore South Denver Metro neighborhoods — market stats, lifestyle info, and active listings.",
      "author": {"@type": "Person", "name": "Jacob Stark"}
    }
    </script>

    <style>
      /* ── Match Me Quiz ── */
      .quiz-section {
        background: var(--color-primary);
        padding: var(--space-3xl) 0;
      }
      .quiz-section .section-label {
        color: var(--color-accent);
      }
      .quiz-section h2 {
        color: #fff;
        font-family: var(--font-heading);
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        margin-bottom: var(--space-sm);
      }
      .quiz-section .quiz-intro {
        color: rgba(255,255,255,0.65);
        margin-bottom: var(--space-xl);
        max-width: 560px;
      }

      .quiz-card {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 16px;
        padding: var(--space-xl) var(--space-xl);
        max-width: 680px;
      }

      .quiz-step { display: none; }
      .quiz-step.active { display: block; }

      .quiz-progress {
        display: flex;
        gap: 8px;
        margin-bottom: var(--space-lg);
      }
      .quiz-progress__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        transition: background 0.2s;
      }
      .quiz-progress__dot.filled { background: var(--color-accent); }

      .quiz-question {
        font-size: 1.1rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: var(--space-md);
      }

      .quiz-options {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .quiz-option {
        background: rgba(255,255,255,0.05);
        border: 1.5px solid rgba(255,255,255,0.15);
        border-radius: 10px;
        padding: 12px 16px;
        color: rgba(255,255,255,0.85);
        font-size: 0.92rem;
        cursor: pointer;
        text-align: left;
        transition: border-color 0.15s, background 0.15s;
        width: 100%;
      }
      .quiz-option:hover {
        border-color: var(--color-accent);
        background: rgba(200,150,90,0.1);
      }
      .quiz-option.selected {
        border-color: var(--color-accent);
        background: rgba(200,150,90,0.15);
        color: #fff;
      }

      .quiz-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: var(--space-lg);
        gap: var(--space-sm);
      }
      .quiz-btn-back {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,0.2);
        color: rgba(255,255,255,0.6);
        border-radius: 8px;
        padding: 10px 20px;
        font-size: 0.88rem;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
      }
      .quiz-btn-back:hover {
        border-color: rgba(255,255,255,0.5);
        color: #fff;
      }
      .quiz-btn-next {
        background: var(--color-accent);
        border: none;
        color: #fff;
        border-radius: 8px;
        padding: 10px 24px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.15s;
      }
      .quiz-btn-next:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }

      /* Results */
      .quiz-results { display: none; }
      .quiz-results.active { display: block; }
      .quiz-results__heading {
        font-size: 1rem;
        color: rgba(255,255,255,0.65);
        margin-bottom: var(--space-md);
      }
      .quiz-results__picks {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: var(--space-lg);
      }
      .quiz-result-chip {
        background: var(--color-accent);
        color: #fff;
        font-weight: 700;
        font-size: 0.85rem;
        border-radius: 24px;
        padding: 8px 18px;
      }
      .quiz-results__note {
        color: rgba(255,255,255,0.55);
        font-size: 0.85rem;
        margin-top: var(--space-sm);
      }
      .quiz-restart-btn {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,0.25);
        color: rgba(255,255,255,0.6);
        border-radius: 8px;
        padding: 8px 18px;
        font-size: 0.82rem;
        cursor: pointer;
        margin-top: var(--space-md);
        transition: border-color 0.15s, color 0.15s;
      }
      .quiz-restart-btn:hover {
        border-color: rgba(255,255,255,0.5);
        color: #fff;
      }

      /* ── Neighborhood Cards ── */
      .neighborhoods-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: var(--space-lg);
      }

      .nbhd-card {
        background: #fff;
        border: 1px solid var(--color-border);
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: box-shadow 0.2s, transform 0.2s;
      }
      .nbhd-card:hover {
        box-shadow: 0 8px 32px rgba(0,42,58,0.1);
        transform: translateY(-2px);
      }
      .nbhd-card.highlighted {
        border-color: var(--color-accent);
        box-shadow: 0 0 0 2px rgba(200,150,90,0.3), 0 8px 32px rgba(0,42,58,0.1);
      }
      .nbhd-card__match-badge {
        display: none;
        background: var(--color-accent);
        color: #fff;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 5px 14px;
        text-align: center;
      }
      .nbhd-card.highlighted .nbhd-card__match-badge {
        display: block;
      }

      .nbhd-card__image {
        height: 200px;
        background-size: cover;
        background-position: center;
      }

      .nbhd-card__body {
        padding: var(--space-lg);
        display: flex;
        flex-direction: column;
        flex: 1;
        gap: var(--space-sm);
      }

      .nbhd-card__county {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
      }

      .nbhd-card__name {
        font-family: var(--font-heading);
        font-size: 1.3rem;
        color: var(--color-primary);
        line-height: 1.2;
      }

      .nbhd-card__personality {
        font-size: 0.92rem;
        color: var(--color-text);
        font-style: italic;
        line-height: 1.5;
        border-left: 3px solid var(--color-accent);
        padding-left: var(--space-sm);
        margin: var(--space-xs) 0;
      }

      .nbhd-card__stats {
        display: flex;
        gap: var(--space-md);
        padding: var(--space-sm) 0;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
      }
      .nbhd-card__stat {
        font-size: 0.8rem;
        color: var(--color-text-muted);
      }
      .nbhd-card__stat strong {
        color: var(--color-primary);
        font-weight: 700;
      }

      .nbhd-card__actions {
        display: flex;
        gap: 10px;
        margin-top: auto;
        padding-top: var(--space-sm);
      }
      .nbhd-card__btn-explore {
        flex: 1;
        background: var(--color-primary);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 0.85rem;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        transition: opacity 0.15s;
        cursor: pointer;
      }
      .nbhd-card__btn-explore:hover { opacity: 0.85; }
      .nbhd-card__btn-search {
        flex: 1;
        background: transparent;
        color: var(--color-primary);
        border: 1.5px solid var(--color-primary);
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 0.85rem;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
        cursor: pointer;
      }
      .nbhd-card__btn-search:hover {
        background: var(--color-primary);
        color: #fff;
      }

      /* ── Matched section header ── */
      .match-header {
        display: none;
        margin-bottom: var(--space-md);
        padding: var(--space-md) var(--space-lg);
        background: rgba(200,150,90,0.08);
        border: 1px solid rgba(200,150,90,0.25);
        border-radius: 10px;
      }
      .match-header.visible { display: block; }
      .match-header p {
        font-size: 0.9rem;
        color: var(--color-text);
        margin: 0;
      }
      .match-header strong { color: var(--color-accent); }

      /* ── Service area map ── */
      .service-area {
        background: var(--color-primary);
        padding: var(--space-3xl) 0;
      }
      .service-area .section-label {
        color: var(--color-accent);
      }
      .service-area h2 {
        color: #fff;
        font-family: var(--font-heading);
        font-size: clamp(1.5rem, 3vw, 2rem);
        margin-bottom: var(--space-sm);
      }
      .service-area__intro {
        color: rgba(255,255,255,0.6);
        max-width: 580px;
        margin-bottom: var(--space-2xl);
      }
      .service-area__grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: var(--space-sm);
      }
      .service-area__city {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        padding: var(--space-md) var(--space-lg);
      }
      .service-area__city-name {
        font-weight: 700;
        color: #fff;
        font-size: 0.95rem;
        margin-bottom: 4px;
      }
      .service-area__city-context {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.45);
        line-height: 1.4;
      }
      .service-area__map-note {
        margin-top: var(--space-xl);
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
        font-style: italic;
      }
    </style>
  </Fragment>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">South Denver Metro</span>
      <h1>Find Your Neighborhood</h1>
      <p>Answer three quick questions and we'll match you to the South Denver communities that fit your life — or browse all nine below.</p>
    </div>
  </section>

  <!-- MATCH ME QUIZ -->
  <section class="quiz-section" id="quiz">
    <div class="container">
      <span class="section-label">Match Me</span>
      <h2>Which South Denver Neighborhood Is Right for You?</h2>
      <p class="quiz-intro">Three questions. Real recommendations based on what actually matters to buyers in this market.</p>

      <div class="quiz-card">
        <!-- Step 1 -->
        <div class="quiz-step active" id="step-1">
          <div class="quiz-progress">
            <div class="quiz-progress__dot filled" id="dot-1"></div>
            <div class="quiz-progress__dot" id="dot-2"></div>
            <div class="quiz-progress__dot" id="dot-3"></div>
          </div>
          <p class="quiz-question">What matters most to you in a location?</p>
          <div class="quiz-options" id="q1-options">
            <button class="quiz-option" data-q="q1" data-val="commute-dtc">Short commute to the DTC</button>
            <button class="quiz-option" data-q="q1" data-val="mountain-access">Mountain access & outdoor lifestyle</button>
            <button class="quiz-option" data-q="q1" data-val="walkable-downtown">Walkable downtown & local shops</button>
            <button class="quiz-option" data-q="q1" data-val="space-privacy">Space, privacy, and room to spread out</button>
            <button class="quiz-option" data-q="q1" data-val="newer-construction">Newer construction and modern amenities</button>
          </div>
          <div class="quiz-nav">
            <span></span>
            <button class="quiz-btn-next" id="next-1" disabled>Next →</button>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="quiz-step" id="step-2">
          <div class="quiz-progress">
            <div class="quiz-progress__dot filled"></div>
            <div class="quiz-progress__dot filled" id="dot-2b"></div>
            <div class="quiz-progress__dot" id="dot-3b"></div>
          </div>
          <p class="quiz-question">What's your budget for a single-family home?</p>
          <div class="quiz-options" id="q2-options">
            <button class="quiz-option" data-q="q2" data-val="under-650k">Under $650K</button>
            <button class="quiz-option" data-q="q2" data-val="650k-750k">$650K – $750K</button>
            <button class="quiz-option" data-q="q2" data-val="750k-950k">$750K – $950K</button>
            <button class="quiz-option" data-q="q2" data-val="950k-plus">$950K+</button>
          </div>
          <div class="quiz-nav">
            <button class="quiz-btn-back" id="back-2">← Back</button>
            <button class="quiz-btn-next" id="next-2" disabled>Next →</button>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="quiz-step" id="step-3">
          <div class="quiz-progress">
            <div class="quiz-progress__dot filled"></div>
            <div class="quiz-progress__dot filled"></div>
            <div class="quiz-progress__dot filled"></div>
          </div>
          <p class="quiz-question">What's your vibe?</p>
          <div class="quiz-options" id="q3-options">
            <button class="quiz-option" data-q="q3" data-val="established-character">Established neighborhoods with real character</button>
            <button class="quiz-option" data-q="q3" data-val="master-planned">Master-planned with trails, rec centers, and HOA perks</button>
            <button class="quiz-option" data-q="q3" data-val="small-town">Small-town feel without the long drive to Denver</button>
            <button class="quiz-option" data-q="q3" data-val="luxury-exclusive">Luxury, exclusivity, and prestige address</button>
          </div>
          <div class="quiz-nav">
            <button class="quiz-btn-back" id="back-3">← Back</button>
            <button class="quiz-btn-next" id="next-3" disabled>See My Matches →</button>
          </div>
        </div>

        <!-- Results -->
        <div class="quiz-results" id="quiz-results">
          <div class="quiz-progress">
            <div class="quiz-progress__dot filled"></div>
            <div class="quiz-progress__dot filled"></div>
            <div class="quiz-progress__dot filled"></div>
          </div>
          <p class="quiz-results__heading">Based on your answers, here are your top matches — highlighted below:</p>
          <div class="quiz-results__picks" id="results-chips"></div>
          <p class="quiz-results__note">Scroll down to explore your matches in detail, or browse all nine neighborhoods.</p>
          <button class="quiz-restart-btn" id="restart-quiz">↻ Start over</button>
        </div>
      </div>
    </div>
  </section>

  <!-- NEIGHBORHOOD CARDS -->
  <section class="section section--white" id="neighborhoods">
    <div class="container">
      <span class="section-label">All Communities</span>
      <h2 class="section-heading">Explore the South Denver Metro</h2>
      <p class="section-subtext">Market data, lifestyle details, and active listings for the communities where families buy and sell with us. Stats: DMAR / REcolorado MLS, Q1 2026.</p>

      <div class="match-header" id="match-header">
        <p>Your quiz results are highlighted. <strong id="match-names"></strong> best match your priorities — but all nine are worth a look.</p>
      </div>

      <div class="neighborhoods-grid" id="neighborhoods-grid">

        <!-- Littleton -->
        <div class="nbhd-card" data-id="littleton">
          <div class="nbhd-card__match-badge">★ Your Match</div>
          <div class="nbhd-card__image" style={`background-image: url('${nbLittleton.src}');`} role="img" aria-label="Suburban street in Littleton, Colorado"></div>
          <div class="nbhd-card__body">
            <span class="nbhd-card__county">Arapahoe County</span>
            <h3 class="nbhd-card__name">Littleton</h3>
            <p class="nbhd-card__personality">Littleton is the Saturday-morning-farmers-market town — a walkable Main Street, light rail, and mountain views without losing your Denver connection.</p>
            <div class="nbhd-card__stats">
              <div class="nbhd-card__stat"><strong>$703,000</strong> Median SFH</div>
              <div class="nbhd-card__stat"><strong>51</strong> Avg DOM</div>
            </div>
            <div class="nbhd-card__actions">
              <a href="/neighborhoods/littleton" class="nbhd-card__btn-explore">Explore Littleton</a>
              <a href="https://selling303.realscout.com/search?city=Littleton" class="nbhd-card__btn-search" target="_blank" rel="noopener">Search Homes</a>
            </div>
          </div>
        </div>

        <!-- Highlands Ranch -->
        <div class="nbhd-card" data-id="highlands-ranch">
          <div class="nbhd-card__match-badge">★ Your Match</div>
          <div class="nbhd-card__image" style={`background-image: url('${nbHighlandsRanch.src}');`} role="img" aria-label="Modern home in Highlands Ranch, Colorado"></div>
          <div class="nbhd-card__body">
            <span class="nbhd-card__county">Douglas County</span>
            <h3 class="nbhd-card__name">Highlands Ranch</h3>
            <p class="nbhd-card__personality">Highlands Ranch is the family command center — 70+ miles of trails, four rec centers, top-rated schools, and resale values that hold.</p>
            <div class="nbhd-card__stats">
              <div class="nbhd-card__stat"><strong>$718,500</strong> Median SFH</div>
              <div class="nbhd-card__stat"><strong>52</strong> Avg DOM</div>
            </div>
            <div class="nbhd-card__actions">
              <a href="/neighborhoods/highlands-ranch" class="nbhd-card__btn-explore">Explore Highlands Ranch</a>
              <a href="https://selling303.realscout.com/search?city=Highlands+Ranch" class="nbhd-card__btn-search" target="_blank" rel="noopener">Search Homes</a>
            </div>
          </div>
        </div>

        <!-- Centennial -->
        <div class="nbhd-card" data-id="centennial">
          <div class="nbhd-card__match-badge">★ Your Match</div>
          <div class="nbhd-card__image" style={`background-image: url('${nbCentennial.src}');`} role="img" aria-label="Residential home in Centennial, Colorado"></div>
          <div class="nbhd-card__body">
            <span class="nbhd-card__county">Arapahoe County</span>
            <h3 class="nbhd-card__name">Centennial</h3>
            <p class="nbhd-card__personality">Centennial is where DTC commuters put down roots — central, established, larger lots, and quietly appreciating year over year.</p>
            <div class="nbhd-card__stats">
              <div class="nbhd-card__stat"><strong>$699,000</strong> Median SFH</div>
              <div class="nbhd-card__stat"><strong>48</strong> Avg DOM</div>
            </div>
            <div class="nbhd-card__actions">
              <a href="/neighborhoods/centennial" class="nbhd-card__btn-explore">Explore Centennial</a>
              <a href="https://selling303.realscout.com/search?city=Centennial" class="nbhd-card__btn-search" target="_blank" rel="noopener">Search Homes</a>
            </div>
          </div>
        </div>

        <!-- Englewood -->
        <div class="nbhd-card" data-id="englewood">
          <div class="nbhd-card__match-badge">★ Your Match</div>
          <div class="nbhd-card__image" style={`background-image: url('${nbEnglewood.src}');`} role="img" aria-label="Residential neighborhood in Englewood, Colorado"></div>
          <div class="nbhd-card__body">
            <span class="nbhd-card__county">Arapahoe County</span>
            <h3 class="nbhd-card__name">Englewood</h3>
            <p class="nbhd-card__personality">Englewood is South Denver's best-kept secret — light rail, walkable pockets, and the lowest entry point in the metro with room to grow.</p>
            <div class="nbhd-card__stats">
              <div class="nbhd-card__stat"><strong>$655,800</strong> Median SFH</div>
              <div class="nbhd-card__stat"><strong>60</strong> Avg DOM</div>
            </div>
            <div class="nbhd-card__actions">
              <a href="/neighborhoods/englewood" class="nbhd-card__btn-explore">Explore Englewood</a>
              <a href="https://selling303.realscout.com/search?city=Englewood" class="nbhd-card__btn-search" target="_blank" rel="noopener">Search Homes</a>
            </div>
          </div>
        </div>

        <!-- Parker -->
        <div class="nbhd-card" data-id="parker">
          <div class="nbhd-card__match-badge">★ Your Match</div>
          <div class="nbhd-card__image" style={`background-image: url('${nbParker.src}');`} role="img" aria-label="Suburban home in Parker, Colorado"></div>
          <div class="nbhd-card__body">
            <span class="nbhd-card__county">Douglas County</span>
            <h3 class="nbhd-card__name">Parker</h3>
            <p class="nbhd-card__personality">Parker is the small town that didn't get swallowed by the suburbs — an active Main Street, elbow room, newer homes, and a real sense of community.</p>
            <div class="nbhd-card__stats">
              <div class="nbhd-card__stat"><strong>$706,324</strong> Median SFH</div>
              <div class="nbhd-card__stat"><strong>62</strong> Avg DOM</div>
            </div>
