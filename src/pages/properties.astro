---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Properties | Selling 303 — Jacob Stark Listings"
  description="Browse Jacob Stark's current and recent listings across South Denver Metro. View homes for sale, in contract, and sold properties in Littleton, Highlands Ranch, Centennial, and beyond."
  ogUrl="https://selling303.com/properties"
  ogImage="https://selling303.com/images/og-properties.jpg"
  currentPage="properties"
  headerVariant="solid"
>
  <Fragment slot="head">
    <!-- RealScout Widget Script -->
    <script src="https://em.realscout.com/widgets/realscout-web-components.umd.js" type="module" is:inline></script>
    <style is:inline>
      realscout-your-listings {
        --rs-listing-divider-color: #c8965a;
        width: 100%;
      }
    </style>

    <!-- Schema: WebPage -->
    <script type="application/ld+json" is:inline>
    {
      "@context":"https://schema.org",
      "@type":"WebPage",
      "name":"Properties | Selling 303",
      "url":"https://selling303.com/properties",
      "description":"Browse Jacob Stark's current and recent listings across South Denver Metro.",
      "author":{
        "@type":"Person",
        "name":"Jacob Stark"
      }
    }
    </script>
  </Fragment>

  <!-- ========== PAGE HERO ========== -->
  <PageHero
    label="Listings"
    heading="My Properties"
    subtext="Current, in-contract, and recent sales across the South Denver Metro"
  />

  <!-- ========== REALSCOUT LISTINGS ========== -->
  <section class="section section--white">
    <div class="container">
      <realscout-your-listings
        agent-encoded-id="QWdlbnQtMjg5MjYw"
        sort-order="STATUS_AND_SIGNIFICANT_CHANGE"
        listing-status="For Sale,In Contract,Sold"
        property-types="SFR,MF,TC,LAL,MOBILE,OTHER"
        include-co-listings
        include-seller-listings
        style="--rs-listing-divider-color: #c8965a;"
      ></realscout-your-listings>
    </div>
  </section>
</BaseLayout>
