---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="First-Time Home Buyer & Seller Guide | South Denver | Jacob Stark, REALTOR®"
  description="First-time buyer or seller in South Denver? Jacob Stark guides you through every step — from pre-approval to closing in Littleton and Highlands Ranch."
  ogType="website"
  ogUrl="https://selling303.com/first-time-buyers-sellers"
  ogImage="https://selling303.com/images/og-default.jpg"
  currentPage="first-time-buyers-sellers"
  headerVariant="solid"
>
  <Fragment slot="head">
    <!-- Schema: RealEstateAgent + Service -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "RealEstateAgent",
      "name": "Jacob Stark",
      "jobTitle": "REALTOR®",
      "url": "https://selling303.com",
      "telephone": "+1-303-997-0634",
      "email": "jacob@selling303.com",
      "image": "https://selling303.com/images/jacob-stark-footer-avatar.png",
      "worksFor": {
        "@type": "RealEstateAgent",
        "name": "8z Real Estate"
      },
      "areaServed": [
        {"@type": "City", "name": "Littleton", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Highlands Ranch", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Centennial", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Englewood", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Parker", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Lakewood", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Lone Tree", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Castle Pines", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Greenwood Village", "containedInPlace": {"@type": "State", "name": "Colorado"}}
      ],
      "makesOffer": {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "First-Time Buyer & Seller Guidance",
          "description": "Jacob Stark guides first-time home buyers and sellers through every step of the buying and selling process in South Denver. Includes pre-approval guidance, neighborhood education, offer strategy, negotiation, and closing support.",
          "serviceType": "Real Estate Buyer and Seller Representation",
          "areaServed": "South Denver Metro, Colorado"
        }
      }
    }
    </script>
    <!-- Schema: FAQPage -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much do I need for a down payment in Colorado?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can buy a home in Colorado with as little as 3% down, though most lenders offer conventional mortgages with 5–20% down. First-time buyers often qualify for special loan programs like FHA (3.5% down) or USDA loans (0% down for eligible rural properties). Jacob Stark connects you with lenders who specialize in first-time buyer financing across South Denver neighborhoods like Littleton, Highlands Ranch, and Centennial. Your down payment depends on your credit score, debt-to-income ratio, and savings — not a fixed requirement."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need an agent as a first-time buyer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You are not required to use an agent, but working with a buyer's agent is almost always in your favor. The seller's brokerage typically pays the buyer's agent commission, so you don't pay extra. Jacob Stark, as your buyer's agent, negotiates on your behalf, explains market conditions in your target neighborhoods, advises on offers, and handles the inspection and appraisal process. Without representation, you're navigating a complex transaction alone — which is risky on your first home."
          }
        },
        {
          "@type": "Question",
          "name": "What does it cost to sell a home in Colorado?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Selling costs in Colorado typically include real estate agent commissions (usually 5–6% split between buyer and seller agents), title insurance, closing attorney fees, survey (if required), and any repairs needed before closing. The total usually runs 8–10% of the sale price. For a $500,000 home in Highlands Ranch, that's roughly $40,000–$50,000. Jacob Stark breaks down every cost upfront before you list, so there are no surprises."
          }
        },
        {
          "@type": "Question",
          "name": "How long does it take to buy a home in South Denver?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "From pre-approval to closing typically takes 4–6 weeks, though it can move faster. Pre-approval takes 1–2 weeks, home search ranges from days to months depending on your preferences, the inspection and appraisal period is 10–14 days, and closing takes 5–7 days. In the South Denver market — Littleton, Highlands Ranch, Centennial, and Parker — competitive neighborhoods can move quickly, so being prepared and pre-approved before you start searching is critical."
          }
        }
      ]
    }
    </script>
  </Fragment>

  <!-- COMPACT PILLAR HERO -->
  <section class="pillar-hero">
    <div class="container">
      <div class="pillar-hero__content">
        <span class="pillar-hero__label">Your Situation</span>
        <h1>Buying or Selling Your First Home in South Denver</h1>
        <p class="pillar-hero__subtitle">A complete guide for first-time buyers and sellers in South Denver. From pre-approval to closing, Jacob Stark walks you through every step with clarity, data, and confidence.</p>
      </div>
    </div>
  </section>


  <!-- PILLAR PAGE BODY: TOC SIDEBAR + CONTENT -->
  <section class="section section--white pillar-body">
    <div class="pillar-layout">

      <!-- STICKY TOC SIDEBAR -->
      <aside class="pillar-toc" aria-label="Page navigation">
        <span class="pillar-toc__label">On This Page</span>
        <ul class="pillar-toc__list">
          <li><a href="#direct-answer" class="pillar-toc__link active">Direct Answer</a></li>
          <li><a href="#the-problem" class="pillar-toc__link">The Problem</a></li>
          <li><a href="#buying-path" class="pillar-toc__link">Buying Your First Home</a></li>
          <li><a href="#selling-path" class="pillar-toc__link">Selling Your First Home</a></li>
          <li><a href="#how-jacob-works" class="pillar-toc__link">How Jacob Works</a></li>
          <li><a href="#areas-served" class="pillar-toc__link">Areas Served</a></li>
          <li><a href="#faq" class="pillar-toc__link">FAQ</a></li>
          <li><a href="#related-reading" class="pillar-toc__link">Related Reading</a></li>
          <li><a href="#why-jacob" class="pillar-toc__link">Why Jacob</a></li>
        </ul>
      </aside>

      <!-- MAIN CONTENT -->
      <div class="pillar-content">

        <!-- DIRECT ANSWER SNIPPET -->
        <div class="snippet-block" id="direct-answer">
          <span class="snippet-block__label">Direct Answer</span>
          <p><strong>What should a first-time home buyer or seller know about the South Denver market?</strong> South Denver neighborhoods like Littleton, Highlands Ranch, and Centennial have median home prices between $450,000 and $650,000, competitive bidding conditions, and attract both move-up families and first-time buyers. Jacob Stark, REALTOR&reg; at 8z Real Estate, specializes in helping first-time buyers and sellers navigate this market from pre-approval through closing.</p>
        </div>


        <!-- THE CHALLENGE -->
        <div id="the-problem" style="padding-top: var(--space-xl);">
          <span class="section-label">The Problem</span>
          <h2 class="section-heading">Buying or Selling Your First Home Is Overwhelming</h2>
          <p>There are financing options you've never considered. Neighborhoods you're still learning about. Offers to make. Inspections to understand. A closing process filled with documents and decisions. And everyone around you has different advice.</p>
          <p>First-time buyers in South Denver suburbs like <a href="/neighborhoods">Littleton</a>, <a href="/neighborhoods">Highlands Ranch</a>, and <a href="/neighborhoods">Centennial</a> often feel uncertain about whether they're making the right choice, overpaying, or missing something critical. First-time sellers worry about pricing correctly, staging effectively, and not leaving money on the table.</p>
          <p>Jacob Stark's job is to remove that uncertainty. He explains each step in plain language, answers every question without judgment, and gives you data so you can make confident decisions about the biggest investment of your life.</p>

          <!-- Inline CTA -->
          <div class="section-cta">
            <p>Ready to start your first-time buying or selling journey? Jacob will listen to your situation and build a clear plan.</p>
            <a href="https://calendly.com/jacob-realtor" class="btn btn--primary btn--sm" target="_blank" rel="noopener">Schedule a Call</a>
          </div>
        </div>


        <!-- BUYING PATH SECTION -->
        <div id="buying-path" style="padding-top: var(--space-2xl);">
          <span class="section-label">For Buyers</span>
          <h2 class="section-heading">Buying Your First Home in South Denver</h2>
          <p style="margin-bottom: var(--space-lg);">Step by step, decision by decision, Jacob Stark guides you through the buying process so you know what to expect and what to avoid.</p>
          <div class="amenities-grid">
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F4B3;</div>
              <div>
                <h4>Pre-Approval</h4>
                <p>Before you start house hunting, Jacob connects you with lenders who work with first-time buyers. Get pre-approved to know your budget, understand different loan types (conventional, FHA, USDA), and see where you stand. Pre-approval also makes your offer stronger in competitive Highlands Ranch and Centennial markets.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F3E0;</div>
              <div>
                <h4>Choosing a Neighborhood</h4>
                <p>South Denver has distinct neighborhoods — Littleton's walkable downtown, Highlands Ranch's master-planned communities, Centennial's parks, Parker's growth, Lakewood's proximity to downtown. Jacob knows schools, commute times, property tax rates, and community character. He helps you narrow down what matters most.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F4DC;</div>
              <div>
                <h4>Making an Offer</h4>
                <p>First-time buyers often don't know what to offer or how competitive to be. Jacob analyzes comparable sales, market conditions, and the specific property to recommend an offer price. He handles the written offer, negotiates terms, and advises on contingencies so you're protected.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F527;</div>
              <div>
                <h4>Home Inspection</h4>
                <p>Jacob schedules your inspection and attends with you. He explains what the inspector finds, what's normal wear vs. a red flag, and negotiates repairs or credits with the seller. A home inspection protects you from major surprises after closing.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F58A;</div>
              <div>
                <h4>Closing Process</h4>
                <p>Walk through your final walkthrough, review your closing disclosure, ask every question you have. Jacob explains the process, answers your lender's final questions, and guides you through signing. Closing happens fast, so being prepared reduces stress.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F50D;</div>
              <div>
                <h4>Post-Close Support</h4>
                <p>Your relationship doesn't end at closing. Jacob provides recommendations for contractors, insurance agents, and local services. He stays in touch, and you have his number if questions come up after you've moved in.</p>
              </div>
            </div>
          </div>
        </div>


        <!-- SELLING PATH SECTION -->
        <div id="selling-path" style="padding-top: var(--space-2xl);">
          <span class="section-label">For Sellers</span>
          <h2 class="section-heading">Selling Your First Home in South Denver</h2>
          <p style="margin-bottom: var(--space-lg);">Selling is different than buying. Jacob Stark walks first-time sellers through preparation, pricing, marketing, and negotiation so your home sells fast and for fair market value.</p>
          <div class="amenities-grid">
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F4C8;</div>
              <div>
                <h4>Market Analysis</h4>
                <p>Jacob pulls current REcolorado MLS comparables for your neighborhood and condition. He shows you what similar homes have sold for recently, how many days they spent on market, and what price range is realistic. This data removes guessing and positions your home correctly from day one.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F3A8;</div>
              <div>
                <h4>Prep &amp; Staging</h4>
                <p>First-time sellers don't always know what buyers notice. Jacob walks through your home, identifies what needs attention (fresh paint, landscaping, decluttering, repairs), and recommends staging guidance. A home that shows well gets more showings and stronger offers.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F4F8;</div>
              <div>
                <h4>Listing Launch</h4>
                <p>Professional photography, video walkthrough, drone images, virtual tour, and a detailed MLS description optimized for buyer searches. Jacob's listings stand out in Littleton, Highlands Ranch, and Centennial markets. Marketing starts immediately across Google, Instagram, and Facebook.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F512;</div>
              <div>
                <h4>Showings &amp; Offers</h4>
                <p>Jacob monitors showing feedback, adjusts strategy if needed, and calls you with every offer that comes in. He explains each offer's strengths and weaknesses so you understand what you're deciding. Multiple offers aren't guaranteed, but preparation and pricing make them more likely.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F4A4;</div>
              <div>
                <h4>Negotiation</h4>
                <p>Not all offers are equal. Some have weak financing, others have contingencies that complicate closing. Jacob recommends which offers to counter, what terms to push back on, and when to accept. He negotiates on your behalf so emotion doesn't cloud judgment.</p>
              </div>
            </div>
            <div class="amenity-item">
              <div class="amenity-item__icon">&#x1F3C3;</div>
              <div>
                <h4>Closing &amp; Next Steps</h4>
                <p>Jacob coordinates title search, appraisal, closing statement review, and final walkthrough. He explains every number and answers your lender's questions. After closing, you have your proceeds and the clarity of knowing you sold smart.</p>
              </div>
            </div>
          </div>
        </div>


        <!-- HOW JACOB WORKS -->
        <div id="how-jacob-works" style="padding-top: var(--space-2xl);">
          <span class="section-label">How Jacob Works</span>
          <h2 class="section-heading">Three Steps to Confidence</h2>
          <p style="margin-bottom: var(--space-lg);">Whether you're buying or selling, the process is the same: understand the situation, build a clear plan, and execute with communication every step of the way.</p>
          <div class="process-steps">
            <div class="process-step">
              <h4>Initial Consultation</h4>
              <p>You share your situation — timeline, budget (if buying), or home details (if selling). Jacob listens, asks questions to understand your priorities, and shares how he works. There's no pressure, just a conversation. You decide if you want to move forward.</p>
            </div>
            <div class="process-step">
              <h4>Customized Game Plan</h4>
              <p>Jacob builds a plan tailored to you. For buyers: pre-approval strategy, neighborhood research, offer approach. For sellers: market analysis, prep checklist, pricing, marketing timeline. You get this plan in writing so you know exactly what to expect and when.</p>
            </div>
            <div class="process-step">
              <h4>Clear Communication Through Closing</h4>
              <p>Jacob stays in touch throughout the process — showing feedback updates, market news, contract timelines, closing coordination. You always know what's happening next and why. No surprises. No gaps. You have his phone number and he answers your questions.</p>
            </div>
          </div>

          <!-- Inline CTA -->
          <div class="section-cta">
            <p>Ready to take the first step? Let's talk about your situation and what comes next.</p>
            <a href="https://calendly.com/jacob-realtor" class="btn btn--primary btn--sm" target="_blank" rel="noopener">Schedule a Call</a>
          </div>
        </div>


        <!-- AREAS SERVED -->
        <div id="areas-served" style="padding-top: var(--space-2xl);">
          <span class="section-label">Areas Served</span>
          <h2 class="section-heading">First-Time Buyer & Seller Help Across South Denver</h2>
          <p>Jacob Stark guides first-time buyers and sellers throughout the South Denver Metro. Whether you're buying your first home in a walkable downtown pocket or selling in a master-planned community, the approach is the same — clear communication, data-backed decisions, confidence at closing.</p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: var(--space-md);">
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Littleton</a>
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Highlands Ranch</a>
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Centennial</a>
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Englewood</a>
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Parker</a>
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Lakewood</a>
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Lone Tree</a>
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Castle Pines</a>
            <a href="/neighborhoods" class="btn btn--outline-dark btn--sm">Greenwood Village</a>
          </div>
        </div>


        <!-- FAQ -->
        <div id="faq" style="padding-top: var(--space-2xl);">
          <span class="section-label">Common Questions</span>
          <h2 class="section-heading">First-Time Buyer &amp; Seller FAQ</h2>
          <div class="faq-list">
            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">How much do I need for a down payment in Colorado?</button>
              <div class="faq-answer">
                <p>You can buy a home in Colorado with as little as 3% down, though most lenders offer conventional mortgages with 5–20% down. First-time buyers often qualify for special loan programs like FHA (3.5% down) or USDA loans (0% down for eligible rural properties). Jacob Stark connects you with lenders who specialize in first-time buyer financing across South Denver neighborhoods like Littleton, Highlands Ranch, and Centennial. Your down payment depends on your credit score, debt-to-income ratio, and savings — not a fixed requirement. Some employers and state programs offer down payment assistance, which Jacob can help you explore.</p>
              </div>
            </div>
            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">Do I need an agent as a first-time buyer?</button>
              <div class="faq-answer">
                <p>You are not required to use an agent, but working with a buyer's agent is almost always in your favor. The seller's brokerage typically pays the buyer's agent commission, so you don't pay extra. Jacob Stark, as your buyer's agent, negotiates on your behalf, explains market conditions in your target neighborhoods, advises on offers, and handles the inspection and appraisal process. Without representation, you're navigating a complex transaction alone — which is risky on your first home. Jacob represents your interests, not the seller's, and you benefit from his market knowledge and negotiating experience.</p>
              </div>
            </div>
            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">What does it cost to sell a home in Colorado?</button>
              <div class="faq-answer">
                <p>Selling costs in Colorado typically include real estate agent commissions (usually 5–6% split between buyer and seller agents), title insurance, closing attorney fees, survey (if required), and any repairs needed before closing. The total usually runs 8–10% of the sale price. For a $500,000 home in Highlands Ranch, that's roughly $40,000–$50,000. Jacob Stark breaks down every cost upfront before you list, so there are no surprises. He also advises on which repairs to prioritize and which to skip based on what buyers value in your specific neighborhood.</p>
              </div>
            </div>
            <div class="faq-item">
              <button class="faq-question" aria-expanded="false">How long does it take to buy a home in South Denver?</button>
              <div class="faq-answer">
                <p>From pre-approval to closing typically takes 4–6 weeks, though it can move faster. Pre-approval takes 1–2 weeks, home search ranges from days to months depending on your preferences, the inspection and appraisal period is 10–14 days, and closing takes 5–7 days. In the South Denver market — Littleton, Highlands Ranch, Centennial, and Parker — competitive neighborhoods can move quickly, so being prepared and pre-approved before you start searching is critical. Jacob keeps the timeline moving and coordinates all parties so nothing slows down your path to closing.</p>
              </div>
            </div>
          </div>
        </div>


        <!-- RELATED READING -->
        <div id="related-reading" style="padding-top: var(--space-2xl);">
          <span class="section-label">Related Reading</span>
          <h2 class="section-heading">First-Time Buyer &amp; Seller Insights</h2>
          <div class="card-grid">
            <a href="/blog" class="card">
              <div class="card__body">
                <span class="card__tag">Buyer Advice</span>
                <h3 class="card__title">Closing Costs for Colorado Home Buyers in 2026</h3>
                <p class="card__text">What you'll pay at closing, how to budget for it, and how to negotiate who covers what. A breakdown of every line item.</p>
                <span class="card__meta">March 2026</span>
              </div>
            </a>
            <a href="/blog" class="card">
              <div class="card__body">
                <span class="card__tag">Buyer Advice</span>
                <h3 class="card__title">What Happens After You Accept an Offer?</h3>
                <p class="card__text">The inspection, appraisal, underwriting, and final walkthrough. Every step explained so you know what's coming next.</p>
                <span class="card__meta">April 2026</span>
              </div>
            </a>
          </div>
        </div>


        <!-- WHY JACOB / TRUST BAR -->
        <div id="why-jacob" style="padding-top: var(--space-2xl);">
          <span class="section-label">Why Jacob</span>
          <h2 class="section-heading">The Numbers Behind the Strategy</h2>
          <p style="margin-bottom: var(--space-lg);">Jacob Stark doesn't just guide first-time buyers and sellers — he closes transactions successfully. These numbers reflect a track record of clear communication, data-backed decisions, and client results across the South Denver Metro.</p>
          <div class="trust-bar">
            <div class="trust-bar__item">
              <span class="trust-bar__value">$46M+</span>
              <span class="trust-bar__label">in Sales</span>
            </div>
            <div class="trust-bar__item">
              <span class="trust-bar__value">100.6%</span>
              <span class="trust-bar__label">Avg Sale-to-List</span>
            </div>
            <div class="trust-bar__item">
              <span class="trust-bar__value">83</span>
              <span class="trust-bar__label">Families Helped</span>
            </div>
            <div class="trust-bar__item">
              <span class="trust-bar__value">5.0</span>
              <span class="trust-bar__label">Google Rating</span>
            </div>
          </div>
        </div>

      </div><!-- /.pillar-content -->
    </div><!-- /.pillar-layout -->
  </section>


  <!-- FINAL CTA -->
  <section class="cta-banner" style="background-color: var(--color-white);">
    <div class="container">
      <h2 style="color: var(--color-dark-text);">Ready to Take the First Step?</h2>
      <p style="color: var(--color-body-text);">Jacob Stark will listen to your situation, answer your questions, and show you exactly what to expect. Whether you're buying or selling, your first move is a conversation. No pressure, no sales pitch — just clarity.</p>
      <a href="https://calendly.com/jacob-realtor" class="btn btn--primary btn--lg" target="_blank" rel="noopener">Schedule a Call</a>
      <a href="tel:3039970634" class="btn btn--outline-dark btn--lg">Call 303-997-0634</a>
    </div>
  </section>

  <script is:inline>
    // FAQ Accordion
    document.querySelectorAll('.faq-question').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item = this.closest('.faq-item');
        var isActive = item.classList.contains('active');
        document.querySelectorAll('.faq-item').forEach(function(el) {
          el.classList.remove('active');
          el.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
        });
        if (!isActive) {
          item.classList.add('active');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Sticky TOC active state
    (function() {
      var tocLinks = document.querySelectorAll('.pillar-toc__link');
      var sections = [];
      tocLinks.forEach(function(link) {
        var id = link.getAttribute('href').replace('#', '');
        var el = document.getElementById(id);
        if (el) sections.push({ id: id, el: el, link: link });
      });

      function updateActive() {
        var scrollPos = window.scrollY + 120;
        var current = sections[0];
        for (var i = 0; i < sections.length; i++) {
          if (sections[i].el.offsetTop <= scrollPos) {
            current = sections[i];
          }
        }
        tocLinks.forEach(function(l) { l.classList.remove('active'); });
        if (current) current.link.classList.add('active');
      }

      window.addEventListener('scroll', updateActive);
      updateActive();
    })();
  </script>
</BaseLayout>
