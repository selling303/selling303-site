---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';

// ── Images ──
import heroImg from '../assets/images/seller-promise/living-room-staged.jpg';
import jacobArchImg from '../assets/images/seller-promise/jacob-architecture.jpg';
import prepImg from '../assets/images/seller-promise/entryway-staged.jpg';
import kitchenCloseImg from '../assets/images/seller-promise/kitchen-closeup.jpg';
import demandImg from '../assets/images/seller-promise/flora-angle-exterior.jpg';
import bedroomImg from '../assets/images/seller-promise/bedroom-styling.jpg';
import launchImg from '../assets/images/seller-promise/open-concept-living.jpg';
import twilightImg from '../assets/images/seller-promise/twilight-exterior.jpg';
import floraAerialImg from '../assets/images/seller-promise/flora-aerial-mountains.jpg';
import aerialImg from '../assets/images/seller-promise/aerial-neighborhood.jpg';

// ── Process for CSS backgrounds ──
const heroBg = await getImage({ src: heroImg, format: 'webp', quality: 85, width: 1920 });
const jacobBg = await getImage({ src: jacobArchImg, format: 'webp', quality: 82, width: 1200 });
const prepBg = await getImage({ src: prepImg, format: 'webp', quality: 82, width: 1400 });
const kitchenBg = await getImage({ src: kitchenCloseImg, format: 'webp', quality: 82, width: 1400 });
const demandBg = await getImage({ src: demandImg, format: 'webp', quality: 82, width: 1400 });
const bedroomBg = await getImage({ src: bedroomImg, format: 'webp', quality: 82, width: 1400 });
const launchBg = await getImage({ src: launchImg, format: 'webp', quality: 82, width: 1400 });
const twilightBg = await getImage({ src: twilightImg, format: 'webp', quality: 82, width: 1400 });
const floraBg = await getImage({ src: floraAerialImg, format: 'webp', quality: 82, width: 1400 });
const aerialBg = await getImage({ src: aerialImg, format: 'webp', quality: 82, width: 1400 });
const livingBg = await getImage({ src: heroImg, format: 'webp', quality: 82, width: 1400 });
---

<BaseLayout
  title="My Seller Promise — A Three-Phase Listing Strategy | Jacob Stark, REALTOR®"
  description="Jacob Stark's structured three-phase approach to selling your home in the South Denver Metro. Data-backed pricing, demand-building marketing, and full transparency from prep to closing."
  ogType="website"
  ogUrl="https://selling303.com/my-seller-promise"
  ogImage="https://selling303.com/images/og-default.jpg"
  currentPage="my-seller-promise"
  headerVariant="solid"
>
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroBg.src} type="image/webp" fetchpriority="high" />

    <!-- Schema: RealEstateAgent + Service -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "RealEstateAgent",
      "name": "Jacob Stark",
      "jobTitle": "REALTOR®",
      "url": "https://selling303.com",
      "telephone": "+1-303-997-0634",
      "email": "jacob@selling303.com",
      "image": "https://selling303.com/images/jacob-stark-footer-avatar.png",
      "worksFor": { "@type": "RealEstateAgent", "name": "8z Real Estate" },
      "areaServed": [
        {"@type": "City", "name": "Littleton", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Highlands Ranch", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Centennial", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Englewood", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Parker", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Lakewood", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Lone Tree", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Castle Pines", "containedInPlace": {"@type": "State", "name": "Colorado"}},
        {"@type": "City", "name": "Greenwood Village", "containedInPlace": {"@type": "State", "name": "Colorado"}}
      ],
      "makesOffer": {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "My Seller Promise — Three-Phase Listing Strategy",
          "description": "Jacob Stark's structured three-phase listing strategy for selling homes in the South Denver Metro.",
          "serviceType": "Real Estate Seller Representation",
          "areaServed": "South Denver Metro, Colorado"
        }
      }
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is the My Seller Promise listing strategy?", "acceptedAnswer": { "@type": "Answer", "text": "My Seller Promise is a three-phase listing strategy used by Jacob Stark, REALTOR® at 8z Real Estate. Phase 1 covers pre-market preparation. Phase 2 builds buyer demand through a 7-day pre-market sequence. Phase 3 is a structured market launch designed to concentrate buyer activity and generate competitive offers." } },
        { "@type": "Question", "name": "How does Jacob Stark price homes differently than other agents?", "acceptedAnswer": { "@type": "Answer", "text": "Jacob uses a data-driven pricing approach that combines MLS comparable sales analysis with real-time buyer engagement data. During the pre-market phase, he monitors Zillow saves, views, and engagement ratios to validate or adjust pricing before the home goes active on the MLS." } },
        { "@type": "Question", "name": "What is the Coming Soon phase and why does it matter?", "acceptedAnswer": { "@type": "Answer", "text": "The Coming Soon phase is a 7-day period before your home goes active on the MLS. It starts with 24 hours of Zillow Preview visibility, followed by 6 days on Coming Soon status across all major portals. This builds buyer anticipation and serves as a final pricing checkpoint before the active clock starts." } },
        { "@type": "Question", "name": "How will I know what's happening with my listing?", "acceptedAnswer": { "@type": "Answer", "text": "Jacob provides every seller with access to ClientClarity, a private seller dashboard that shows showing activity, buyer feedback, marketing milestones, and market context in real time." } },
        { "@type": "Question", "name": "What happens if my home doesn't get an offer in the first week?", "acceptedAnswer": { "@type": "Answer", "text": "If the offer deadline passes without an accepted offer, Jacob moves immediately — calling every showing agent, collecting feedback, debriefing with you within 24 hours, and recommending a price adjustment if the market signals point to price." } }
      ]
    }
    </script>
  </Fragment>

  <style is:global>
    /* ─────────────────────────────────
       TOKENS
    ───────────────────────────────── */
    :root {
      --sp-dark: #002a3a;
      --sp-gold: #C8956C;
      --sp-light: #f7f5f2;
      --sp-white: #ffffff;
      --sp-serif: 'DM Serif Display', serif;
      --sp-ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ─────────────────────────────────
       REVEAL
    ───────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.9s var(--sp-ease), transform 0.9s var(--sp-ease);
    }
    .reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─────────────────────────────────
       HERO
    ───────────────────────────────── */
    .sp-hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: #fff;
      overflow: hidden;
    }
    .sp-hero__bg {
      position: absolute; inset: 0;
      background-size: cover;
      background-position: center 40%;
    }
    .sp-hero__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(180deg, rgba(0,42,58,.82) 0%, rgba(0,42,58,.68) 50%, rgba(0,42,58,.88) 100%);
      z-index: 1;
    }
    .sp-hero__content {
      position: relative; z-index: 2;
      max-width: 720px;
      padding: 6rem 1.5rem 4rem;
    }
    .sp-hero__label {
      display: inline-block;
      font-size: .7rem; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--sp-gold);
      border: 1px solid rgba(200,149,108,.35);
      padding: .4rem 1.2rem; border-radius: 99px;
      margin-bottom: 2rem;
    }
    .sp-hero h1 {
      font-family: var(--sp-serif);
      font-size: clamp(2.8rem, 7vw, 5rem);
      line-height: 1.05; margin-bottom: 1.5rem;
      color: #fff; letter-spacing: -0.02em;
    }
    .sp-hero__sub {
      font-size: clamp(1rem, 2vw, 1.15rem);
      line-height: 1.7; opacity: .8;
      max-width: 540px; margin: 0 auto 2.5rem;
    }
    .sp-hero__tagline {
      font-family: var(--sp-serif);
      font-style: italic;
      font-size: clamp(1.1rem, 2.5vw, 1.35rem);
      color: var(--sp-gold);
    }
    .sp-hero__scroll {
      position: absolute; bottom: 2rem; left: 50%;
      transform: translateX(-50%); z-index: 2;
      text-align: center; color: rgba(255,255,255,.5);
      font-size: .65rem; font-weight: 600;
      letter-spacing: .15em; text-transform: uppercase;
    }
    .sp-hero__scroll-line {
      width: 1px; height: 40px;
      background: rgba(255,255,255,.25);
      margin: .5rem auto 0;
      animation: scrollPulse 2s ease-in-out infinite;
    }
    @keyframes scrollPulse { 0%,100%{opacity:.3} 50%{opacity:.8} }


    /* ─────────────────────────────────
       PROMISE — FULL-BLEED PHOTO + FLOATING TEXT
    ───────────────────────────────── */
    .sp-promise {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .sp-promise__photo {
      position: absolute; inset: 0;
      background-size: cover;
      background-position: 30% center;
    }
    .sp-promise__photo-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(
        90deg,
        rgba(0,42,58,0.05) 0%,
        rgba(0,42,58,0.15) 30%,
        rgba(0,42,58,0.7) 55%,
        rgba(0,42,58,0.95) 72%,
        rgba(0,42,58,0.98) 100%
      );
    }
    .sp-promise__text {
      position: relative; z-index: 1;
      margin-left: auto;
      width: 50%;
      padding: clamp(3rem, 6vw, 6rem);
      color: #fff;
    }
    .sp-promise__text h2 {
      font-family: var(--sp-serif);
      font-size: clamp(2rem, 4.5vw, 3.4rem);
      line-height: 1.1;
      margin-bottom: 1.5rem;
      letter-spacing: -0.02em;
      color: #fff;
    }
    .sp-promise__text p {
      font-size: clamp(1rem, 1.6vw, 1.1rem);
      line-height: 1.8;
      opacity: .7;
      max-width: 440px;
    }


    /* ─────────────────────────────────
       PHASE OVERVIEW CARDS
    ───────────────────────────────── */
    .sp-overview {
      background: var(--sp-light);
      padding: 6rem 2rem;
      text-align: center;
    }
    .sp-overview__label {
      display: block;
      font-size: .7rem; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--sp-gold);
      margin-bottom: 1rem;
    }
    .sp-overview__title {
      font-family: var(--sp-serif);
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      color: var(--sp-dark);
      margin-bottom: 3rem;
      letter-spacing: -0.02em;
    }
    .sp-overview__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem;
    }
    @media (max-width: 768px) {
      .sp-overview__grid {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding: 0 1.5rem;
        gap: 1rem;
      }
      .sp-overview__grid::-webkit-scrollbar { display: none; }
      .sp-ov-card {
        flex: 0 0 80vw;
        scroll-snap-align: center;
      }
    }
    .sp-ov-card {
      background: var(--sp-white);
      border-radius: 16px;
      padding: 2.5rem 2rem;
      text-align: left;
      box-shadow: 0 2px 20px rgba(0,42,58,.06);
      transition: transform 0.4s var(--sp-ease);
    }
    .sp-ov-card:hover { transform: translateY(-4px); }
    .sp-ov-card__num {
      font-family: var(--sp-serif);
      font-size: 3rem; color: var(--sp-gold);
      line-height: 1; margin-bottom: .75rem;
    }
    .sp-ov-card__name {
      font-family: var(--sp-serif);
      font-size: 1.6rem; color: var(--sp-dark);
      margin-bottom: 1rem;
    }
    .sp-ov-card__desc {
      font-size: .95rem; line-height: 1.7; color: #555;
    }


    /* ─────────────────────────────────
       PHASE DEEP DIVE — HORIZONTAL CAROUSEL
    ───────────────────────────────── */
    .sp-phase {
      background: var(--sp-dark);
      padding: 0;
    }
    .sp-phase__intro {
      text-align: center;
      padding: 4rem 2rem 2rem;
    }
    .sp-phase__num {
      display: block;
      font-size: .65rem; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--sp-gold);
      margin-bottom: .75rem;
    }
    .sp-phase__title {
      font-family: var(--sp-serif);
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      color: #fff;
      letter-spacing: -0.02em;
      line-height: 1.08;
    }
    .sp-carousel {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 0;
      padding-bottom: 1.5rem;
    }
    .sp-carousel::-webkit-scrollbar { display: none; }
    .sp-card {
      flex: 0 0 min(92vw, 1200px);
      scroll-snap-align: center;
      height: 60vh;
      min-height: 400px;
      border-radius: 16px;
      overflow: hidden;
      position: relative;
      margin: 0 0.75rem;
      display: flex;
      align-items: flex-end;
    }
    .sp-card:first-child { margin-left: max(1.5rem, calc((100vw - 1200px) / 2)); }
    .sp-card:last-child { margin-right: max(1.5rem, calc((100vw - 1200px) / 2)); }
    .sp-card__bg {
      position: absolute; inset: 0;
      background-size: cover;
      background-position: center;
      transition: transform 0.6s var(--sp-ease);
    }
    .sp-card:hover .sp-card__bg { transform: scale(1.03); }
    .sp-card__overlay {
      position: absolute; inset: 0;
      background: linear-gradient(180deg, rgba(0,42,58,0) 20%, rgba(0,42,58,.88) 100%);
    }
    .sp-card__text {
      position: relative; z-index: 1;
      padding: 2.5rem;
      color: #fff;
      max-width: 520px;
    }
    .sp-card__text p {
      font-size: clamp(1.05rem, 2vw, 1.25rem);
      line-height: 1.6;
    }
    .sp-card__accent {
      font-family: var(--sp-serif);
      font-style: italic;
      color: #fff;
      font-size: clamp(1.15rem, 2.2vw, 1.35rem);
      line-height: 1.45;
      padding-left: 1.25rem;
      border-left: 3px solid var(--sp-gold);
    }
    .sp-carousel__dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      padding-bottom: 2.5rem;
    }
    .sp-carousel__dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: rgba(255,255,255,.25);
      transition: background .3s ease, transform .3s var(--sp-ease);
    }
    .sp-carousel__dot.is-active {
      background: var(--sp-gold);
      transform: scale(1.5);
    }

    /* Light phase variant */
    .sp-phase--light {
      background: var(--sp-light);
    }
    .sp-phase--light .sp-phase__title { color: var(--sp-dark); }
    .sp-phase--light .sp-carousel__dot { background: rgba(0,42,58,.15); }
    .sp-phase--light .sp-carousel__dot.is-active { background: var(--sp-gold); }


    /* ─────────────────────────────────
       CTA BAND
    ───────────────────────────────── */
    .sp-cta {
      background: var(--sp-dark);
      text-align: center;
      padding: 6rem 2rem;
      color: #fff;
    }
    .sp-cta h2 {
      font-family: var(--sp-serif);
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
      color: #fff;
    }
    .sp-cta p {
      font-size: 1.05rem; opacity: .7;
      margin-bottom: 2.5rem;
      max-width: 480px; margin-left: auto; margin-right: auto;
    }
    .sp-cta__buttons {
      display: flex; gap: 1rem;
      justify-content: center; flex-wrap: wrap;
    }
    .btn--gold {
      display: inline-block;
      background: var(--sp-gold); color: var(--sp-dark);
      font-weight: 600; font-size: .9rem;
      padding: .9rem 2rem; border-radius: 8px;
      text-decoration: none;
      transition: background .3s ease, transform .2s ease;
    }
    .btn--gold:hover { background: #b8855c; transform: translateY(-1px); }
    .btn--ghost {
      display: inline-block;
      border: 1px solid rgba(255,255,255,.25); color: #fff;
      font-weight: 600; font-size: .9rem;
      padding: .9rem 2rem; border-radius: 8px;
      text-decoration: none;
      transition: border-color .3s ease, transform .2s ease;
    }
    .btn--ghost:hover { border-color: rgba(255,255,255,.5); transform: translateY(-1px); }


    /* ─────────────────────────────────
       TECH — HORIZONTAL SCROLL
    ───────────────────────────────── */
    .sp-tech {
      background: var(--sp-light);
      padding: 6rem 0;
      overflow: hidden;
    }
    .sp-tech__header {
      text-align: center;
      padding: 0 2rem;
      margin-bottom: 3rem;
    }
    .sp-tech__header span {
      display: block;
      font-size: .7rem; font-weight: 700;
      letter-spacing: .18em; text-transform: uppercase;
      color: var(--sp-gold); margin-bottom: 1rem;
    }
    .sp-tech__header h2 {
      font-family: var(--sp-serif);
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      color: var(--sp-dark); letter-spacing: -0.02em;
    }
    .sp-tech__track {
      display: flex; gap: 1.5rem;
      overflow-x: auto; scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 0 max(1.5rem, calc((100vw - 920px) / 2));
      scrollbar-width: none;
    }
    .sp-tech__track::-webkit-scrollbar { display: none; }
    .sp-tech-card {
      flex: 0 0 min(85vw, 440px);
      scroll-snap-align: center;
      border-radius: 16px;
      padding: 3rem 2.5rem;
    }
    .sp-tech-card--clarity {
      background: var(--sp-dark); color: #fff;
    }
    .sp-tech-card--price {
      background: var(--sp-white); color: var(--sp-dark);
      border: 1px solid rgba(0,42,58,.08);
    }
    .sp-tech-card__status {
      display: inline-block;
      font-size: .6rem; font-weight: 700;
      letter-spacing: .12em; text-transform: uppercase;
      padding: .3rem .8rem; border-radius: 99px;
      margin-bottom: 1.5rem;
    }
    .sp-tech-card--clarity .sp-tech-card__status { background: rgba(200,149,108,.2); color: var(--sp-gold); }
    .sp-tech-card--price .sp-tech-card__status { background: rgba(200,149,108,.15); color: #9a7050; }
    .sp-tech-card__name {
      font-family: var(--sp-serif);
      font-size: 1.8rem; margin-bottom: .75rem;
    }
    .sp-tech-card__tagline {
      font-family: var(--sp-serif);
      font-style: italic; font-size: 1.1rem;
      color: var(--sp-gold); margin-bottom: 1.5rem;
    }
    .sp-tech-card__desc {
      font-size: .95rem; line-height: 1.7; opacity: .75;
    }
    .sp-tech-card__features {
      list-style: none; padding: 0; margin: 1.5rem 0 0;
    }
    .sp-tech-card__features li {
      font-size: .9rem; padding: .5rem 0;
      border-top: 1px solid rgba(255,255,255,.08);
      display: flex; align-items: center; gap: .5rem;
    }
    .sp-tech-card--price .sp-tech-card__features li { border-top-color: rgba(0,42,58,.06); }
    .sp-tech-card__features li::before {
      content: ''; width: 4px; height: 4px;
      border-radius: 50%; background: var(--sp-gold); flex-shrink: 0;
    }
    .sp-tech-card__btn {
      display: block;
      text-align: center;
      margin-top: 1.5rem;
      background: var(--sp-gold); color: var(--sp-dark);
      font-weight: 600; font-size: .85rem;
      padding: .7rem 1.5rem; border-radius: 8px;
      text-decoration: none;
      transition: background .3s ease, transform .2s ease;
    }
    .sp-tech-card__btn:hover { background: #b8855c; transform: translateY(-1px); }


    /* ─────────────────────────────────
       TRUST BAR
    ───────────────────────────────── */
    .sp-trust {
      background: var(--sp-dark);
      padding: 5rem 2rem;
    }
    .sp-trust__inner {
      max-width: 900px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 2rem; text-align: center;
    }
    .sp-trust__value {
      font-family: var(--sp-serif);
      font-size: clamp(2rem, 4vw, 2.8rem);
      color: var(--sp-gold); margin-bottom: .25rem;
    }
    .sp-trust__label {
      font-size: .75rem; font-weight: 600;
      letter-spacing: .08em; text-transform: uppercase;
      color: rgba(255,255,255,.5);
    }


    /* ─────────────────────────────────
       FAQ
    ───────────────────────────────── */
    .sp-faq {
      background: var(--sp-light);
      padding: 6rem 2rem;
    }
    .sp-faq__inner { max-width: 680px; margin: 0 auto; }
    .sp-faq h2 {
      font-family: var(--sp-serif);
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      color: var(--sp-dark); text-align: center;
      margin-bottom: 3rem;
    }
    .faq-item { border-bottom: 1px solid rgba(0,42,58,.08); }
    .faq-question {
      width: 100%; text-align: left;
      background: none; border: none;
      padding: 1.25rem 2.5rem 1.25rem 0;
      font-size: 1rem; font-weight: 600;
      color: var(--sp-dark); cursor: pointer;
      position: relative;
    }
    .faq-question::after {
      content: '+'; position: absolute;
      right: 0; top: 50%; transform: translateY(-50%);
      font-size: 1.4rem; font-weight: 300;
      color: var(--sp-gold); transition: transform .3s ease;
    }
    .faq-item.active .faq-question::after { content: '−'; }
    .faq-answer {
      max-height: 0; overflow: hidden;
      transition: max-height .4s var(--sp-ease);
    }
    .faq-item.active .faq-answer { max-height: 300px; }
    .faq-answer p {
      padding: 0 0 1.25rem;
      font-size: .95rem; line-height: 1.7; color: #555;
    }


    /* ─────────────────────────────────
       AREAS
