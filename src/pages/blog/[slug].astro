---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import avatarSrc from '../../assets/images/jacob-stark-avatar.png';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

// Resolve related posts from the blog collection at build time
const allPosts = await getCollection('blog');
const postsBySlug = new Map(allPosts.map((p) => [p.id, p]));

// Category → gradient class + SVG icon mapping (shared with blog index)
const categoryMeta: Record<string, { gradient: string; icon: string }> = {
  'Costs & Pricing': {
    gradient: 'cat-grad--costs',
    icon: '<circle cx="14" cy="14" r="11" stroke="rgba(255,255,255,0.4)" stroke-width="1.2"/><text x="14" y="18.5" text-anchor="middle" fill="rgba(255,255,255,0.75)" font-size="13" font-weight="600" font-family="Inter,sans-serif">$</text>',
  },
  'Problems & Mistakes': {
    gradient: 'cat-grad--problems',
    icon: '<path d="M14 4L26 24H2L14 4Z" stroke="rgba(255,255,255,0.4)" stroke-width="1.2" stroke-linejoin="round"/><line x1="14" y1="11" x2="14" y2="17" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="20" r="1" fill="rgba(255,255,255,0.6)"/>',
  },
  'Comparisons': {
    gradient: 'cat-grad--comparisons',
    icon: '<rect x="3" y="8" width="9" height="14" rx="1.5" stroke="rgba(255,255,255,0.4)" stroke-width="1.2"/><rect x="16" y="5" width="9" height="17" rx="1.5" stroke="rgba(255,255,255,0.4)" stroke-width="1.2"/><line x1="11.5" y1="14" x2="16.5" y2="14" stroke="rgba(255,255,255,0.4)" stroke-width="1.2" stroke-dasharray="2 2"/>',
  },
  'Best Of': {
    gradient: 'cat-grad--bestof',
    icon: '<path d="M14 3L17 11H25L19 16L21 24L14 19L7 24L9 16L3 11H11L14 3Z" stroke="rgba(255,255,255,0.4)" stroke-width="1.2" stroke-linejoin="round"/>',
  },
  'What to Expect': {
    gradient: 'cat-grad--expect',
    icon: '<rect x="5" y="3" width="18" height="22" rx="2.5" stroke="rgba(255,255,255,0.4)" stroke-width="1.2"/><line x1="10" y1="9" x2="18" y2="9" stroke="rgba(255,255,255,0.35)" stroke-width="1.2"/><line x1="10" y1="14" x2="18" y2="14" stroke="rgba(255,255,255,0.35)" stroke-width="1.2"/><line x1="10" y1="19" x2="15" y2="19" stroke="rgba(255,255,255,0.35)" stroke-width="1.2"/>',
  },
  'Neighborhoods': {
    gradient: 'cat-grad--neighborhoods',
    icon: '<path d="M14 3C10 3 7 6.5 7 10.5C7 16 14 25 14 25C14 25 21 16 21 10.5C21 6.5 18 3 14 3Z" stroke="rgba(255,255,255,0.4)" stroke-width="1.2"/><circle cx="14" cy="10.5" r="2.5" stroke="rgba(255,255,255,0.4)" stroke-width="1.2"/>',
  },
};

function getCatMeta(category: string) {
  return categoryMeta[category] || categoryMeta['What to Expect'];
}

// Build Article JSON-LD
const articleSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": data.headline || data.title,
  "description": data.description,
  "image": data.ogImage || data.cardImage?.url || "https://selling303.com/images/og-default.jpg",
  "author": {
    "@type": "Person",
    "name": "Jacob Stark",
    "jobTitle": "REALTOR®",
    "url": "https://selling303.com/about",
    "worksFor": { "@type": "Organization", "name": "8z Real Estate" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Selling 303",
    "url": "https://selling303.com",
    "logo": { "@type": "ImageObject", "url": "https://selling303.com/images/selling303-logo.png" }
  },
  "datePublished": data.date,
  "dateModified": data.dateModified || data.date,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://selling303.com/blog/${entry.id}`
  }
};

if (data.aboutPlaces && data.aboutPlaces.length > 0) {
  articleSchema.about = data.aboutPlaces.map((place: string) => ({
    "@type": "Place",
    "name": place
  }));
}

if (data.keywords) {
  articleSchema.keywords = data.keywords;
}

const articleSchemaJson = JSON.stringify(articleSchema);

// Build FAQ JSON-LD if present
let faqSchemaJson: string | null = null;
if (data.faqSchema && data.faqSchema.length > 0) {
  faqSchemaJson = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": data.faqSchema.map((faq: { question: string; answer: string }) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
    }))
  });
}

const ogImage = data.ogImage || data.cardImage?.url || "https://selling303.com/images/og-default.jpg";
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogType="article"
  ogUrl={`https://selling303.com/blog/${entry.id}`}
  ogImage={ogImage}
  currentPage="blog"
  headerVariant="solid"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={articleSchemaJson} />
    {faqSchemaJson && <script type="application/ld+json" is:inline set:html={faqSchemaJson} />}
  </Fragment>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">{data.heroLabel}</span>
      <h1>{data.title}</h1>
      <p>{data.heroSubtext}</p>
    </div>
  </section>

  <!-- ARTICLE -->
  <article class="article" itemscope itemtype="https://schema.org/Article">
    <meta itemprop="headline" content={data.headline || data.title} />
    <meta itemprop="datePublished" content={data.date} />
    <meta itemprop="dateModified" content={data.dateModified || data.date} />
    {data.aboutPlaces && data.aboutPlaces.map((place: string) => (
      <meta itemprop="about" content={place} />
    ))}
    <!-- AUTHOR BLOCK -->
    <div class="article__meta" itemprop="author" itemscope itemtype="https://schema.org/Person">
      <Image src={avatarSrc} alt="Jacob Stark, REALTOR® at 8z Real Estate" class="article__author-photo" width={48} height={48} format="webp" quality={80} itemprop="image" />
      <div>
        <span class="article__author-name" itemprop="name">Jacob Stark</span>
        <meta itemprop="jobTitle" content="REALTOR®" />
        <span>{data.date} &middot; {data.readTime}</span>
      </div>
    </div>

    <!-- ARTICLE BODY (rendered from markdown) -->
    <div itemprop="articleBody">
      <Content />
    </div>
  </article>

  <!-- RELATED POSTS -->
  {data.relatedPosts && data.relatedPosts.length > 0 && (
    <section class="section related-posts">
      <div class="container">
        <span class="section-label">Keep Reading</span>
        <h2 class="section-heading">Related Posts</h2>
        <div class="card-grid">
          {data.relatedPosts.map((post) => {
            const resolved = postsBySlug.get(post.slug);
            const category = resolved?.data.category || 'What to Expect';
            const meta = getCatMeta(category);
            const stat = resolved?.data.cardStat;
            const statLabel = resolved?.data.cardStatLabel;
            const hasStat = stat && statLabel;
            return (
              <a href={`/blog/${post.slug}`} class="card">
                <div class={`card__header ${meta.gradient}`}>
                  <div class="card__header-default">
                    <svg class="card__header-icon" viewBox="0 0 28 28" fill="none" set:html={meta.icon} />
                    <span class="card__header-cat">{category}</span>
                  </div>
                  {hasStat && (
                    <div class="card__header-reveal">
                      <span class="card__header-stat">{stat}</span>
                      <span class="card__header-stat-label">{statLabel}</span>
                    </div>
                  )}
                </div>
                <div class="card__body">
                  <span class="card__tag">{post.tag}</span>
                  <h3 class="card__title">{post.title}</h3>
                  <p class="card__text">{post.description}</p>
                  <span class="card__meta">{post.date}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="cta-banner">
    <div class="container">
      <h2>Have a Question?</h2>
      <p>If something you read here raised a question about your situation, I'm happy to talk it through — no obligation.</p>
      <a href="https://calendly.com/jacob-realtor" class="btn btn--primary btn--lg" target="_blank" rel="noopener">Schedule a Call</a>
    </div>
  </section>
</BaseLayout>
