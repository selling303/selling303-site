---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
import { Image } from 'astro:assets';
import headshotSrc from '../assets/images/jacob-stark-headshot.png';
import lifestyleKitchenSrc from '../assets/images/jacob-lifestyle-kitchen.jpg';
import badgeDmar from '../assets/images/ea25_digitalawards_gold.png';
import badgeRene from '../assets/images/rene-color.png';
import badgeWwlre from '../assets/images/WWLRE_BLACK.png';
import badge5280 from '../assets/images/5280-magazine-black.png';
import badgeRtv from '../assets/images/rtv-black.png';
---

<BaseLayout
  title="About Jacob Stark | Selling 303 — South Denver REALTOR"
  description="Jacob Stark is your guide through South Denver Metro real estate. Learn how he helps families buy and sell with clarity, confidence, and control."
  ogType="profile"
  ogUrl="https://selling303.com/about"
  ogImage="https://selling303.com/images/og-about.jpg"
  currentPage="about"
  headerVariant="solid"
>
  <Fragment slot="head">
    <!-- Schema: Person + RealEstateAgent (canonical bio page) -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": ["Person", "RealEstateAgent"],
      "@id": "https://selling303.com/#agent",
      "name": "Jacob Stark",
      "alternateName": "Selling 303",
      "jobTitle": "REALTOR®",
      "url": "https://selling303.com/about",
      "mainEntityOfPage": "https://selling303.com/about",
      "image": "https://selling303.com/images/jacob-stark-headshot.png",
      "telephone": "+1-303-997-0634",
      "email": "jacob@selling303.com",
      "description": "South Denver Metro REALTOR specializing in Littleton, Highlands Ranch, Centennial, Parker, and surrounding communities. Guiding buyers and sellers with clarity, confidence, and control.",
      "worksFor": {
        "@type": "Organization",
        "name": "8z Real Estate",
        "url": "https://8z.com"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "7935 E Prentice Ave, Suite 105",
        "addressLocality": "Greenwood Village",
        "addressRegion": "CO",
        "postalCode": "80111",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "City", "name": "Littleton", "containedInPlace": { "@type": "State", "name": "Colorado" } },
        { "@type": "City", "name": "Highlands Ranch", "containedInPlace": { "@type": "State", "name": "Colorado" } },
        { "@type": "City", "name": "Centennial", "containedInPlace": { "@type": "State", "name": "Colorado" } },
        { "@type": "City", "name": "Englewood", "containedInPlace": { "@type": "State", "name": "Colorado" } },
        { "@type": "City", "name": "Parker", "containedInPlace": { "@type": "State", "name": "Colorado" } },
        { "@type": "City", "name": "Lakewood", "containedInPlace": { "@type": "State", "name": "Colorado" } },
        { "@type": "City", "name": "Lone Tree", "containedInPlace": { "@type": "State", "name": "Colorado" } },
        { "@type": "City", "name": "Castle Pines", "containedInPlace": { "@type": "State", "name": "Colorado" } },
        { "@type": "City", "name": "Greenwood Village", "containedInPlace": { "@type": "State", "name": "Colorado" } }
      ],
      "knowsAbout": [
        "home selling",
        "home buying",
        "real estate pricing strategy",
        "South Denver Metro real estate",
        "comparative market analysis",
        "real estate negotiation",
        "investment property analysis"
      ],
      "hasCredential": [
        {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "Professional Certification",
          "name": "Real Estate Negotiation Expert (RENE)"
        },
        {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "Professional Membership",
          "name": "Who's Who in Luxury Real Estate"
        }
      ],
      "award": [
        "DMAR Excellence Award — Silver Level (2024)",
        "DMAR Excellence Award — Gold Level (2025)",
        "DMAR Excellence Award — Silver Level (2026)",
        "5280 Magazine Top Real Estate Producer — Black Diamond",
        "Real Trends Verified"
      ],
      "memberOf": [
        {
          "@type": "Organization",
          "name": "Denver Metro Association of REALTORS (DMAR)"
        },
        {
          "@type": "Organization",
          "name": "Who's Who in Luxury Real Estate"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "47",
        "bestRating": "5"
      },
      "sameAs": [
        "https://jacobstark.8z.com/",
        "https://www.google.com/maps/place/?q=Jacob+Stark+Real+Estate",
        "https://www.zillow.com/profile/jacobstarkrealtor",
        "https://www.realtor.com/realestateagents/5ef4c015aa95460011ac4a5b",
        "https://www.linkedin.com/in/jacobstark",
        "https://www.instagram.com/jacobstark_realtor/",
        "https://www.facebook.com/jacobstarkrealtor/",
        "https://www.youtube.com/@selling303",
        "https://www.youtube.com/channel/UCTr7LNftWL7F63Bw-rcdxLg",
        "https://www.fastexpert.com/agents/jacob-stark-109720/",
        "https://www.homes.com/real-estate-agents/jacob-stark/fr1k64r/",
        "https://nextdoor.com/pages/jacob-stark-realtor-greenwood-village-co/",
        "https://www.realtrends.com/agent-profile/jacob-stark-colorado/",
        "https://directory.5280.com/real_estate_agent/jacob-stark/",
        "https://www.wikidata.org/wiki/Q139385406"
      ]
    }
    </script>
  </Fragment>

  <!-- ========== PAGE HERO ========== -->
  <PageHero
    label="About Jacob"
    heading="Meet Jacob Stark"
    subtext="REALTOR® at 8z Real Estate · Your Guide Through South Denver Metro Real Estate"
  />

  <!-- ========== BIO SECTION ========== -->
  <section class="section section--white">
    <div class="container">
      <div class="two-col">
        <div class="about-images">
          <div class="two-col__image two-col__image--portrait">
            <Image
              src={headshotSrc}
              alt="Jacob Stark, REALTOR at 8z Real Estate — professional headshot, South Denver Metro real estate agent"
              width={750}
              height={750}
              format="webp"
              quality={80}
              loading="eager"
            />
          </div>
          <div class="two-col__image">
            <Image
              src={lifestyleKitchenSrc}
              alt="Jacob Stark reviewing a home with clients in a modern kitchen in Denver, Colorado"
              width={1200}
              height={800}
              format="webp"
              quality={80}
              loading="lazy"
            />
          </div>
        </div>
        <div>
          <span class="section-label">The Short Version</span>
          <h2 class="section-heading">Real Estate Done Differently</h2>
          <p>I got into real estate because I watched too many families make one of the biggest financial decisions of their lives without a real guide in their corner. Generic advice, vague timelines, pressure to decide fast. That didn't sit right.</p>
          <p>Before I became a REALTOR®, I was a marketer. I flipped houses. I learned what it feels like to be on the other side of the table — and I decided that if I was going to do this job, I was going to do it differently. Every decision backed by real data, every update delivered clearly, and every client treated like someone whose future actually matters.</p>
          <p>I specialize in the South Denver Metro — Littleton, Highlands Ranch, Centennial, Englewood, Parker, Lakewood, Lone Tree, Castle Pines, and Greenwood Village. I know these neighborhoods at the HOA level, the street level, and the comps level. That specificity matters when you're making a $600K+ decision.</p>
          <p>Whether you're a growing family looking to move up, a seller trying to maximize your net, or an investor running deal numbers — you'll get the same thing from me: honest context, a clear strategy, and someone who actually picks up the phone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRACK RECORD ========== -->
  <section class="section">
    <div class="container text-center">
      <span class="section-label">By the Numbers</span>
      <h2 class="section-heading">Track Record</h2>
      <div class="credentials">
        <div class="credential">
          <span class="credential__number">$46M+</span>
          <span class="credential__label">Career Sales Volume</span>
        </div>
        <div class="credential">
          <span class="credential__number">83</span>
          <span class="credential__label">Families Helped</span>
        </div>
        <div class="credential">
          <span class="credential__number">Top 10</span>
          <span class="credential__label">Agent by Verified Sales — RealTrends</span>
        </div>
        <div class="credential">
          <span class="credential__number">Top 1.5%</span>
          <span class="credential__label">of U.S. Real Estate Professionals</span>
        </div>
        <div class="credential">
          <span class="credential__number">100.6%</span>
          <span class="credential__label">Avg Sale-to-List</span>
        </div>
        <div class="credential">
          <span class="credential__number">5.0</span>
          <span class="credential__label">Google Rating</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== AWARDS & RECOGNITION ========== -->
  <section class="section section--white badges-section">
    <div class="container text-center">
      <span class="section-label">Recognition</span>
      <h2 class="section-heading">Awards & Designations</h2>
      <div class="badge-bar">
        <a href="https://www.dmarealtors.com/excellenceawards" target="_blank" rel="noopener" class="badge-item badge-item--dmar">
          <Image
            src={badgeDmar}
            alt="Denver Metro Association of REALTORS Excellence Award — Gold Level, 2025"
            width={300}
            format="webp"
            quality={85}
            loading="lazy"
          />
        </a>
        <a href="https://directory.5280.com/real_estate_agent/jacob-stark/" target="_blank" rel="noopener" class="badge-item">
          <Image
            src={badge5280}
            alt="5280 Magazine Top Real Estate Producer — Black Diamond"
            width={400}
            format="webp"
            quality={85}
            loading="lazy"
          />
        </a>
        <a href="https://www.realtrends.com/agent-profile/jacob-stark-colorado/" target="_blank" rel="noopener" class="badge-item">
          <Image
            src={badgeRtv}
            alt="Real Trends Verified Agent"
            width={400}
            format="webp"
            quality={85}
            loading="lazy"
          />
        </a>
        <div class="badge-item">
          <Image
            src={badgeWwlre}
            alt="Who's Who in Luxury Real Estate member"
            width={400}
            format="webp"
            quality={85}
            loading="lazy"
          />
        </div>
        <div class="badge-item">
          <Image
            src={badgeRene}
            alt="Real Estate Negotiation Expert (RENE) certification"
            width={400}
            format="webp"
            quality={85}
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA BANNER ========== -->
  <CTABanner
    heading="Ready to Talk?"
    subtext="No pitch, no pressure. Just a conversation about your goals and whether working together makes sense."
  />
</BaseLayout>

<style>
  .badges-section {
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
    border-top: 1px solid #e8e8e8;
  }

  .badge-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    margin-top: 2rem;
  }

  .badge-item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .badge-item img {
    height: 65px;
    width: auto !important;
    max-width: none !important;
    object-fit: contain;
  }

  .badge-item--dmar img {
    height: 110px;
  }

  @media (max-width: 768px) {
    .badge-bar {
      gap: 2rem;
    }

    .badge-item img {
      height: 45px;
    }

    .badge-item--dmar img {
      height: 80px;
    }
  }
</style>
