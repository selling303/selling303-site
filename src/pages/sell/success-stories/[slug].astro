    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: #fff;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .ss-lightbox__prev { left: 16px; }
  .ss-lightbox__next { right: 16px; }
  .ss-lightbox__prev:hover,
  .ss-lightbox__next:hover { background: rgba(255, 255, 255, 0.2); }
  .ss-lightbox__stage {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ss-lightbox__img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 4px;
    user-select: none;
    -webkit-user-drag: none;
  }
  .ss-lightbox__caption {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.8125rem;
    text-align: center;
    max-width: 600px;
    font-family: var(--font-body, 'Inter', sans-serif);
  }
  @media (max-width: 768px) {
    .ss-lightbox__prev,
    .ss-lightbox__next { width: 40px; height: 40px; }
    .ss-lightbox__prev { left: 8px; }
    .ss-lightbox__next { right: 8px; }
  }
</style>

<script define:vars={{ galleryImages: JSON.stringify(resolvedImages) }}>
  (function() {
    const images = JSON.parse(galleryImages);
    if (!images.length) return;

    const trigger = document.querySelector('.ss-hero-image__trigger');
    const lightbox = document.getElementById('ss-lightbox');
    if (!trigger || !lightbox) return;

    const img = lightbox.querySelector('.ss-lightbox__img');
    const counter = lightbox.querySelector('.ss-lightbox__counter');
    const caption = lightbox.querySelector('.ss-lightbox__caption');
    const closeBtn = lightbox.querySelector('.ss-lightbox__close');
    const prevBtn = lightbox.querySelector('.ss-lightbox__prev');
    const nextBtn = lightbox.querySelector('.ss-lightbox__next');
    const backdrop = lightbox.querySelector('.ss-lightbox__backdrop');

    let current = 0;
    let touchStartX = 0;

    function show(index) {
      current = (index + images.length) % images.length;
      img.src = images[current].src;
      img.alt = images[current].alt;
      counter.textContent = (current + 1) + ' / ' + images.length;
      caption.textContent = images[current].alt;
      prevBtn.style.display = images.length <= 1 ? 'none' : '';
      nextBtn.style.display = images.length <= 1 ? 'none' : '';
    }

    function open(index) {
      show(index);
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lightbox.hidden = true;
      document.body.style.overflow = '';
    }

    // Hero image click opens lightbox at photo 0
    trigger.addEventListener('click', function() { open(0); });

    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);
    prevBtn.addEventListener('click', function() { show(current - 1); });
    nextBtn.addEventListener('click', function() { show(current + 1); });

    // Keyboard navigation
    document.addEventListener('keydown', function(e) {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });

    // Touch swipe
    lightbox.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    lightbox.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) {
        dx > 0 ? show(current - 1) : show(current + 1);
      }
    }, { passive: true });

    // FAQ Accordion (matches pillar page behavior — one open at a time)
    document.querySelectorAll('.faq-question').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item = this.closest('.faq-item');
        var isOpen = item.classList.contains('active');
        document.querySelectorAll('.faq-item').forEach(function(el) {
          el.classList.remove('active');
          el.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('active');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>
