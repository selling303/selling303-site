---
interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogImage = 'https://selling303.com/images/og-default.jpg',
  ogUrl = Astro.url.href,
  ogType = 'website',
  canonicalUrl = Astro.url.href,
} = Astro.props;
---

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>

<!-- Preload critical fonts — self-hosted, no third-party round-trip -->
<link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/fonts/dm-serif-display-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>

<!-- Preconnect hints — early TLS handshake for third-party origins -->
<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>

<!-- Open Graph -->
<meta property="og:title" content={ogTitle}>
<meta property="og:description" content={ogDescription}>
<meta property="og:type" content={ogType}>
<meta property="og:url" content={ogUrl}>
<meta property="og:image" content={ogImage}>

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl}>

<link rel="icon" href="/favicon.ico" type="image/x-icon">

<!-- Google Analytics 4 — deferred until first interaction or idle to eliminate
     critical-path forced reflow (GA's early gtag('config') reads layout properties).
     Pageviews still fire as soon as GA initializes; only very short bounces (<3s, no interaction) are missed. -->
<script is:inline>
  (function () {
    window.dataLayer = window.dataLayer || [];
    window.gtag = function () { dataLayer.push(arguments); };

    // Phone-link click tracking — fires the tel_click conversion event whenever
    // a user taps any <a href="tel:..."> on the site. Registered globally so it
    // covers FloatingCTA, Footer, CTABanner, and every pillar/contact page CTA
    // without per-page changes. Use capture phase so the event queues before
    // the browser hands the click off to the dialer.
    document.addEventListener('click', function (e) {
      var a = e.target && e.target.closest && e.target.closest('a[href^="tel:"]');
      if (!a) return;
      gtag('event', 'tel_click', {
        link_url: a.href,
        link_text: (a.textContent || '').trim().slice(0, 80),
        page_path: location.pathname
      });
    }, { capture: true });

    var initialized = false;
    function initGA() {
      if (initialized) return;
      initialized = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=G-WLGW57VN8C';
      document.head.appendChild(s);
      gtag('js', new Date());
      gtag('config', 'G-WLGW57VN8C');
    }

    // Initialize on first meaningful user interaction
    var events = ['scroll', 'click', 'keydown', 'mousemove', 'touchstart'];
    function onInteraction() {
      events.forEach(function (e) { window.removeEventListener(e, onInteraction, { passive: true }); });
      initGA();
    }
    events.forEach(function (e) { window.addEventListener(e, onInteraction, { once: true, passive: true }); });

    // Fallback: initialize after idle / 3s timeout so zero-interaction visits still register
    if ('requestIdleCallback' in window) {
      requestIdleCallback(initGA, { timeout: 3000 });
    } else {
      setTimeout(initGA, 3000);
    }
  })();
</script>

