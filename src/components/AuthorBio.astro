---
import { Image } from 'astro:assets';
import avatarSrc from '../assets/images/jacob-stark-avatar.png';

interface Props {
  compact?: boolean;
  date?: string;
}

const { compact = false, date } = Astro.props;
---

{compact ? (
  <div style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem;">
    <Image
      src={avatarSrc}
      alt="Jacob Stark"
      width={32}
      height={32}
      format="webp"
      quality={80}
      style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;"
    />
    <div>
      <div style="font-weight: 600; color: var(--color-dark-text);">Jacob Stark</div>
      <div style="color: var(--color-body-text);">
        REALTOR® at 8z Real Estate
        {date && <span> · {date}</span>}
      </div>
    </div>
  </div>
) : (
  <div style="padding: var(--space-md) 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div style="display: flex; align-items: flex-start; gap: 1.5rem;">
      <Image
        src={avatarSrc}
        alt="Jacob Stark"
        width={80}
        height={80}
        format="webp"
        quality={80}
        style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
      />
      <div>
        <h3 style="margin: 0 0 0.25rem 0; color: var(--color-dark-text);">Jacob Stark</h3>
        <p style="margin: 0 0 1rem 0; color: var(--color-body-text); font-weight: 500;">
          REALTOR® at 8z Real Estate
        </p>
        <p style="margin: 0 0 1rem 0; color: var(--color-body-text); line-height: 1.6;">
          Jacob Stark is a top-performing REALTOR® specializing in South Denver Metro real estate. With over a decade of experience and a track record of over $46M in career sales volume, Jacob helps families and investors navigate the complexities of buying, selling, and investing in real estate.
        </p>
        <a href="/about" style="color: var(--color-accent); text-decoration: none; font-weight: 600;">
          Learn more about Jacob →
        </a>
      </div>
    </div>
  </div>
)}
