---
/**
 * NeighborhoodCard — renders a neighborhood card with Schema.org Place Microdata.
 * Supports two variants: "compact" (homepage) and "full" (neighborhoods page).
 *
 * Compact usage (homepage):
 *   <NeighborhoodCard variant="compact" name="Littleton" slug="littleton"
 *     description="Historic downtown charm..." medianPrice={703000}
 *     medianPriceDisplay="$703K" dom={51} imageSrc={nbLittleton.src}
 *     imageAlt="Suburban home in Littleton, Colorado" />
 *
 * Full usage (neighborhoods page):
 *   <NeighborhoodCard variant="full" name="Littleton" slug="littleton"
 *     county="Arapahoe County" description="Littleton is the Saturday-morning..."
 *     medianPrice={703000} medianPriceDisplay="$703,000" dom={51}
 *     imageSrc={nbLittleton.src} imageAlt="Suburban street in Littleton"
 *     searchUrl="https://selling303.realscout.com/search?city=Littleton" />
 */
interface Props {
  /** "compact" for homepage cards, "full" for neighborhoods page */
  variant: 'compact' | 'full';
  /** City name, e.g. "Littleton" */
  name: string;
  /** URL slug, e.g. "littleton" or "highlands-ranch" */
  slug: string;
  /** County name — required for full variant */
  county?: string;
  /** Description or personality text */
  description: string;
  /** Machine-readable median price (number), e.g. 703000 */
  medianPrice: number;
  /** Display string for the price, e.g. "$703K" or "$703,000" */
  medianPriceDisplay: string;
  /** Average days on market (number) */
  dom: number;
  /** Optimized image URL from getImage() */
  imageSrc: string;
  /** Alt text for the image */
  imageAlt: string;
  /** RealScout search URL — required for full variant */
  searchUrl?: string;
}

const {
  variant,
  name,
  slug,
  county,
  description,
  medianPrice,
  medianPriceDisplay,
  dom,
  imageSrc,
  imageAlt,
  searchUrl,
} = Astro.props;

const fullName = `${name}, Colorado`;
const priceLabel = variant === 'full' ? 'Median Single-Family Home Price' : 'Median Home Price';
---

<style>
  /* ── Full variant (neighborhoods page) ── */
  .nbhd-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .nbhd-card:hover {
    box-shadow: 0 8px 32px rgba(0,42,58,0.1);
    transform: translateY(-2px);
  }
  .nbhd-card.highlighted {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 2px rgba(200,150,90,0.3), 0 8px 32px rgba(0,42,58,0.1);
  }
  .nbhd-card__match-badge {
    display: none;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 5px 14px;
    text-align: center;
  }
  .nbhd-card.highlighted .nbhd-card__match-badge {
    display: block;
  }
  .nbhd-card__image {
    height: 200px;
    background-size: cover;
    background-position: center;
  }
  .nbhd-card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-sm);
  }
  .nbhd-card__county {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }
  .nbhd-card__name {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-primary);
    line-height: 1.2;
  }
  .nbhd-card__personality {
    font-size: 0.92rem;
    color: var(--color-text);
    font-style: italic;
    line-height: 1.5;
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-sm);
    margin: var(--space-xs) 0;
  }
  .nbhd-card__stats {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .nbhd-card__stat {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .nbhd-card__stat strong {
    color: var(--color-primary);
    font-weight: 700;
  }
  .nbhd-card__actions {
    display: flex;
    gap: 10px;
    margin-top: auto;
    padding-top: var(--space-sm);
  }
  .nbhd-card__btn-explore {
    flex: 1;
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.15s;
    cursor: pointer;
  }
  .nbhd-card__btn-explore:hover { opacity: 0.85; }
  .nbhd-card__btn-search {
    flex: 1;
    background: transparent;
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    cursor: pointer;
  }
  .nbhd-card__btn-search:hover {
    background: var(--color-primary);
    color: #fff;
  }
</style>

{variant === 'compact' ? (
  <a href={`/neighborhoods/${slug}`} class="card" itemscope itemtype="https://schema.org/Place">
    <meta itemprop="name" content={fullName} />
    <div class="card__image" style={`background-image: url('${imageSrc}');`} role="img" aria-label={imageAlt}></div>
    <div class="card__body">
      <span class="card__tag">{name}</span>
      <h3 class="card__title" itemprop="alternateName">{name}</h3>
      <p class="card__text" itemprop="description">{description}</p>
      <div class="card__stats">
        <div class="card__stat" itemprop="additionalProperty" itemscope itemtype="https://schema.org/PropertyValue">
          <meta itemprop="name" content={priceLabel} />
          <meta itemprop="value" content={String(medianPrice)} />
          <strong>{medianPriceDisplay}</strong> Median Price
        </div>
        <div class="card__stat" itemprop="additionalProperty" itemscope itemtype="https://schema.org/PropertyValue">
          <meta itemprop="name" content="Average Days on Market" />
          <meta itemprop="value" content={String(dom)} />
          <strong>{dom}</strong> Avg DOM
        </div>
      </div>
    </div>
  </a>
) : (
  <div class={`nbhd-card`} data-id={slug} itemscope itemtype="https://schema.org/Place">
    <meta itemprop="name" content={fullName} />
    <div class="nbhd-card__match-badge">★ Your Match</div>
    <div class="nbhd-card__image" style={`background-image: url('${imageSrc}');`} role="img" aria-label={imageAlt}></div>
    <div class="nbhd-card__body">
      {county && (
        <span class="nbhd-card__county" itemprop="containedInPlace" itemscope itemtype="https://schema.org/AdministrativeArea">
          <span itemprop="name">{county}</span>
        </span>
      )}
      <h3 class="nbhd-card__name" itemprop="alternateName">{name}</h3>
      <p class="nbhd-card__personality" itemprop="description">{description}</p>
      <div class="nbhd-card__stats">
        <div class="nbhd-card__stat" itemprop="additionalProperty" itemscope itemtype="https://schema.org/PropertyValue">
          <meta itemprop="name" content={priceLabel} />
          <meta itemprop="value" content={String(medianPrice)} />
          <strong>{medianPriceDisplay}</strong> Median SFH
        </div>
        <div class="nbhd-card__stat" itemprop="additionalProperty" itemscope itemtype="https://schema.org/PropertyValue">
          <meta itemprop="name" content="Average Days on Market" />
          <meta itemprop="value" content={String(dom)} />
          <strong>{dom}</strong> Avg DOM
        </div>
      </div>
      <div class="nbhd-card__actions">
        <a href={`/neighborhoods/${slug}`} class="nbhd-card__btn-explore">Explore {name}</a>
        {searchUrl && (
          <a href={searchUrl} class="nbhd-card__btn-search" target="_blank" rel="noopener">Search Homes</a>
        )}
      </div>
    </div>
  </div>
)}
