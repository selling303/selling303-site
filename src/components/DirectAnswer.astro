---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div class="direct-answer" style="background-color: #f0f6f9; border-left: 4px solid var(--color-accent); padding: var(--space-md) var(--space-lg); margin-bottom: var(--space-lg); border-radius: 0 8px 8px 0;">
  <p style="font-weight: 700; font-size: 1.125rem; color: var(--color-dark-text); margin-bottom: 0.5rem;">{question}</p>
  <p style="color: var(--color-body-text); margin: 0; line-height: 1.7;">{answer}</p>
</div>
