      </div>
      <div>
        <h4 class="footer__heading">Quick Links</h4>
        <ul class="footer__links">
          <li><a href="/neighborhoods">Search Homes</a></li>
          <li><a href="/properties">Properties</a></li>
          <li><a href="/about">About Jacob</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href="/#home-value">Home Value</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer__heading">Neighborhoods</h4>
        <ul class="footer__links">
          {neighborhoods.map((n) => (
            <li><a href={`/neighborhoods/${n.slug}`}>{n.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="footer__heading">Stay in the Loop</h4>
        <p class="footer__newsletter-text">Market updates, real talk, and insights for South Denver buyers and sellers.</p>
        <form class="footer__newsletter-form" name="newsletter" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="newsletter">
          <input type="email" name="email" placeholder="Your email" required>
          <button type="submit" class="btn btn--primary btn--sm">Join</button>
