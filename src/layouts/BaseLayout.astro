---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  canonicalUrl?: string;
  currentPage?: string;
  headerVariant?: 'transparent' | 'solid';
  extraHead?: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  ogUrl,
  ogType,
  canonicalUrl,
  currentPage = '',
  headerVariant = 'transparent',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SEO
    title={title}
    description={description}
    ogTitle={ogTitle}
    ogDescription={ogDescription}
    ogImage={ogImage}
    ogUrl={ogUrl}
    ogType={ogType}
    canonicalUrl={canonicalUrl}
  />
  <slot name="head" />
</head>
<body>
  <Header currentPage={currentPage} variant={headerVariant} />

  <slot />

  <Footer />
  <FloatingCTA />

  <script src="/js/main.js" is:inline></script>
</body>
</html>
